<%- include('partials/head', { title: 'Login', navbar: false }) %>

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-sm-10 col-md-6 col-lg-5 col-xl-4">
        <div class="text-center mb-4">
            <span class="material-icons-outlined text-success" style="font-size: 3.5rem;">inventory_2</span>
            <h2 class="fw-bold mt-2">Craftbox</h2>
            <p class="text-body-secondary">Sign in to manage your servers.</p>
        </div>
        <div class="card">
            <div class="card-body p-4">
                <form method="POST" action="/login" novalidate>
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="mb-3">
                        <label for="username" class="form-label">Username</label>
                        <div class="input-group">
                            <span class="input-group-text"><span class="material-icons-outlined" style="font-size: 1.2rem;">person</span></span>
                            <input type="text" class="form-control" id="username" name="username" required autofocus placeholder="Username">
                        </div>
                    </div>
                    <div class="mb-4">
                        <label for="password" class="form-label">Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><span class="material-icons-outlined" style="font-size: 1.2rem;">lock</span></span>
                            <input type="password" class="form-control" id="password" name="password" required placeholder="Password">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success w-100 d-flex align-items-center justify-content-center gap-2">
                        <span class="material-icons-outlined" style="font-size: 1.2rem;">login</span>
                        Sign In
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('partials/foot', { scripts: [] }) %>
