<%- include('../partials/head', { title: 'Error', navbar: typeof user !== 'undefined' && user, fluid: false }) %>

<div class="text-center py-5">
    <span class="material-icons-outlined text-danger mb-3" style="font-size: 5rem;">error</span>
    <h2 class="fw-bold">500 — Internal Server Error</h2>
    <p class="text-body-secondary mb-4"><%= typeof message !== 'undefined' && message ? message : 'Something went wrong. Please try again.' %></p>
    <a href="/dashboard" class="btn btn-outline-success d-inline-flex align-items-center gap-2">
        <span class="material-icons-outlined" style="font-size: 1.2rem;">home</span>
        Back to Dashboard
    </a>
</div>

<%- include('../partials/foot', { scripts: [] }) %>
