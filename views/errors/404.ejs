    <h2 class="fw-bold">404 — Not Found</h2>
    <p class="text-body-secondary mb-4"><%= typeof message !== 'undefined' && message ? message : 'The page you are looking for does not exist.' %></p>
    <a href="/dashboard" class="btn btn-outline-success d-inline-flex align-items-center gap-2">
        <span class="material-icons-outlined" style="font-size: 1.2rem;">home</span>
