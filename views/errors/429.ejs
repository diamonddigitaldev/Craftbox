<%- include('../partials/head', { title: 'Too Many Requests', navbar: false, fluid: false }) %>

<div class="text-center py-5">
    <span class="material-icons-outlined text-warning mb-3" style="font-size: 5rem;">speed</span>
    <h2 class="fw-bold">429 — Too Many Requests</h2>
    <p class="text-body-secondary mb-4"><%= typeof message !== 'undefined' && message ? message : 'You have made too many requests. Please wait and try again.' %></p>
    <a href="/login" class="btn btn-outline-success d-inline-flex align-items-center gap-2">
        <span class="material-icons-outlined" style="font-size: 1.2rem;">login</span>
        Back to Login
    </a>
</div>

<%- include('../partials/foot', { scripts: [] }) %>
