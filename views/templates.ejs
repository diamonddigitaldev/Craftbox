<%- include('partials/head', { title: 'Templates', navbar: true, fluid: true }) %>

<input type="hidden" name="_csrf" value="<%= csrfToken %>">

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 d-flex align-items-center gap-2">
        <span class="material-icons-outlined">bookmark</span>
        Templates
    </h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-8">

        <% if (templates && templates.length > 0) { %>
            <div class="card">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th style="width: 100px;">Type</th>
                                <th style="width: 100px;">Version</th>
                                <th style="width: 100px;">Memory</th>
                                <th style="width: 80px;">Port</th>
                                <th style="width: 130px;">Created</th>
                                <th style="width: 100px;"></th>
                            </tr>
                        </thead>
                        <tbody id="templates-table">
                            <% templates.forEach(function(t) { %>
                                <tr data-template-id="<%= t.id %>">
                                    <td class="fw-semibold"><%= t.name %></td>
                                    <td>
                                        <span class="badge bg-secondary">
                                            <%= (t.serverType || 'vanilla').charAt(0).toUpperCase() + (t.serverType || 'vanilla').slice(1) %>
                                        </span>
                                    </td>
                                    <td><%= t.serverType === 'custom' ? '—' : (t.version || '—') %></td>
                                    <td><%= t.memory %> MB</td>
                                    <td><%= t.port %></td>
                                    <td><span class="format-date" data-iso="<%= t.createdAt %>" data-style="date"></span></td>
                                    <td class="text-end">
                                        <button type="button" class="btn btn-outline-danger btn-sm d-inline-flex align-items-center gap-1 delete-template-btn"
                                            data-template-id="<%= t.id %>" data-template-name="<%= t.name %>"
                                            data-csrf="<%= csrfToken %>">
                                            <span class="material-icons-outlined" style="font-size: 1rem;">delete</span>
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } else { %>
            <div class="text-center py-5">
                <span class="material-icons-outlined text-body-secondary mb-3" style="font-size: 4rem;">bookmark_border</span>
                <h5 class="text-body-secondary">No templates yet</h5>
                <p class="text-body-secondary mb-0">Save a template from any server's settings page.</p>
            </div>
        <% } %>
    </div>
</div>

<!-- Delete Template Modal -->
<div class="modal fade" id="deleteTemplateModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-danger">delete</span>
                    Delete Template
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Permanently delete template "<span id="delete-template-name"></span>"?
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm" id="confirm-delete-template-btn">Delete</button>
            </div>
        </div>
    </div>
</div>

<%- include('partials/foot', { scripts: ['/js/templates.js'] }) %>
