<%- include('../partials/head', { title: server.name + ' — Events', navbar: true, fluid: true }) %>
<%- include('../partials/serverNav', { server, active: 'events' }) %>

<%
const eventIcons = {
    started: 'play_circle',
    stopped: 'stop_circle',
    crashed: 'error',
    restarted: 'restart_alt',
    player_join: 'login',
    player_leave: 'logout',
    action: 'person',
    backup_create: 'backup',
    backup_restore: 'settings_backup_restore',
    backup_delete: 'delete'
};
const eventColors = {
    started: 'text-success',
    stopped: 'text-secondary',
    crashed: 'text-danger',
    restarted: 'text-info',
    player_join: 'text-success',
    player_leave: 'text-warning',
    action: 'text-primary',
    backup_create: 'text-info',
    backup_restore: 'text-warning',
    backup_delete: 'text-secondary'
};
const eventLabels = {
    started: 'Started',
    stopped: 'Stopped',
    crashed: 'Crashed',
    restarted: 'Restarted',
    player_join: 'Player Join',
    player_leave: 'Player Leave',
    action: 'Action',
    backup_create: 'Backup Created',
    backup_restore: 'Backup Restored',
    backup_delete: 'Backup Deleted'
};

// Collect unique event types for filter dropdown
const allTypes = [...new Set(events.map(e => e.type))].sort();
%>

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <h5 class="mb-0 d-flex align-items-center gap-2">
        <span class="material-icons-outlined" style="font-size: 1.3rem;">history</span>
        Event Log
        <span class="badge bg-secondary fw-normal" style="font-size: 0.75rem;"><%= events.length %></span>
    </h5>
    <div class="d-flex align-items-center gap-2">
        <label class="text-body-secondary" style="font-size: 0.85rem;" for="event-type-filter">Filter:</label>
        <select class="form-select form-select-sm" id="event-type-filter" style="width: auto;" onchange="window.location.href = this.value ? '/servers/<%= server.id %>/events?type=' + this.value : '/servers/<%= server.id %>/events'">
            <option value="">All Events</option>
            <% allTypes.forEach(function(t) { %>
            <option value="<%= t %>" <%= typeFilter === t ? 'selected' : '' %>><%= eventLabels[t] || t %></option>
            <% }) %>
        </select>
        <% if (events.length > 0) { %>
        <form id="clear-events-form" method="POST" action="/servers/<%= server.id %>/events/clear">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-outline-danger btn-sm d-flex align-items-center gap-1">
                <span class="material-icons-outlined" style="font-size: 1rem;">delete_sweep</span> Clear
            </button>
        </form>
        <% } %>
    </div>
</div>

<% if (events.length === 0) { %>
<div class="card">
    <div class="card-body text-center py-5">
        <span class="material-icons-outlined text-body-secondary mb-2" style="font-size: 3rem; opacity: 0.3;">history</span>
        <p class="text-body-secondary mb-0">No events recorded<%= typeFilter ? ' for this filter' : '' %>.</p>
    </div>
</div>
<% } else { %>
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover table-sm mb-0 align-middle">
            <thead>
                <tr>
                    <th style="width: 2.5rem;"></th>
                    <th>Event</th>
                    <th>Details</th>
                    <th style="width: 10rem;">Initiated By</th>
                    <th style="width: 12rem;">Time</th>
                </tr>
            </thead>
            <tbody>
                <% events.forEach(function(event) { %>
                <tr>
                    <td class="text-center">
                        <span class="material-icons-outlined <%= eventColors[event.type] || 'text-body-secondary' %>" style="font-size: 1.1rem;">
                            <%= eventIcons[event.type] || 'info' %>
                        </span>
                    </td>
                    <td>
                        <span class="badge bg-<%= event.type === 'crashed' ? 'danger' : event.type === 'started' || event.type === 'player_join' ? 'success' : event.type === 'restarted' || event.type === 'backup_create' ? 'info' : event.type === 'action' ? 'primary' : event.type === 'backup_restore' || event.type === 'player_leave' ? 'warning' : 'secondary' %>" style="font-size: 0.75rem;">
                            <%= eventLabels[event.type] || event.type %>
                        </span>
                    </td>
                    <td><%= event.message %></td>
                    <td>
                        <% if (event.initiatedBy) { %>
                        <span class="d-flex align-items-center gap-1">
                            <span class="material-icons-outlined" style="font-size: 0.9rem;">person</span>
                            <%= event.initiatedBy %>
                        </span>
                        <% } else if (event.playerName) { %>
                        <span class="d-flex align-items-center gap-1">
                            <span class="material-icons-outlined" style="font-size: 0.9rem;">sports_esports</span>
                            <%= event.playerName %>
                        </span>
                        <% } else { %>
                        <span class="text-body-secondary" style="font-size: 0.85rem;">System</span>
                        <% } %>
                    </td>
                    <td>
                        <small class="text-body-secondary text-nowrap event-time" data-time="<%= event.createdAt %>"><%= event.createdAt %></small>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% } %>

<!-- Clear Events Confirmation Modal -->
<div class="modal fade" id="clearEventsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-danger">delete_sweep</span>
                    Clear Event Log
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                This will permanently delete all <strong><%= events.length %></strong> logged events for <strong><%= server.name %></strong>. This cannot be undone.
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm" id="confirm-clear">Clear Events</button>
            </div>
        </div>
    </div>
</div>

<!-- Clear Events Overlay -->
<div id="clear-overlay" class="d-none position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
     style="z-index: 1050; background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);">
    <div class="text-center">
        <div class="spinner-border text-success mb-3" style="width: 3rem; height: 3rem;" role="status">
            <span class="visually-hidden">Clearing events...</span>
        </div>
        <h5 class="mb-1">Clearing events...</h5>
        <p class="text-body-secondary mb-0">Deleting all logged events for this server.</p>
    </div>
</div>

<%- include('../partials/foot', { scripts: ['/js/events.js'] }) %>
