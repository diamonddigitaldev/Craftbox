<%- include('../partials/head', { title: server.name + ' Events', navbar: true, fluid: true }) %>
<%- include('../partials/serverNav', { server, active: 'events' }) %>

<%
// One entry per event type logged by src/utils/eventLogger.js callers. Every
// type needs all four fields — a missing label renders the raw id in the badge
// and the filter dropdown.
const eventMeta = {
    started:             { icon: 'play_circle',              color: 'text-success',   badge: 'success',   label: 'Started' },
    stopped:             { icon: 'stop_circle',              color: 'text-secondary', badge: 'secondary', label: 'Stopped' },
    crashed:             { icon: 'error',                    color: 'text-danger',    badge: 'danger',    label: 'Crashed' },
    restarted:           { icon: 'restart_alt',              color: 'text-info',      badge: 'info',      label: 'Restarted' },
    player_join:         { icon: 'login',                    color: 'text-success',   badge: 'success',   label: 'Player Join' },
    player_leave:        { icon: 'logout',                   color: 'text-warning',   badge: 'warning',   label: 'Player Leave' },
    action:              { icon: 'person',                   color: 'text-primary',   badge: 'primary',   label: 'Action' },
    jar_upgrade:         { icon: 'upgrade',                  color: 'text-info',      badge: 'info',      label: 'Jar Upgraded' },
    jar_upgrade_fail:    { icon: 'upgrade',                  color: 'text-danger',    badge: 'danger',    label: 'Upgrade Failed' },
    backup_create:       { icon: 'backup',                   color: 'text-info',      badge: 'info',      label: 'Backup Created' },
    backup_create_fail:  { icon: 'backup',                   color: 'text-danger',    badge: 'danger',    label: 'Backup Failed' },
    backup_restore:      { icon: 'settings_backup_restore',  color: 'text-info',      badge: 'info',      label: 'Backup Restored' },
    backup_restore_fail: { icon: 'settings_backup_restore',  color: 'text-danger',    badge: 'danger',    label: 'Restore Failed' },
    backup_delete:       { icon: 'delete',                   color: 'text-secondary', badge: 'secondary', label: 'Backup Deleted' }
};
const FALLBACK_META = { icon: 'info', color: 'text-body-secondary', badge: 'secondary', label: null };
const metaFor = (type) => eventMeta[type] || FALLBACK_META;
// Filter dropdown shows labels; an unknown type falls back to its raw id.
const eventLabels = Object.fromEntries(
    Object.entries(eventMeta).map(([type, meta]) => [type, meta.label])
);
%>

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <h5 class="mb-0 d-flex align-items-center gap-2">
        <span class="material-icons-outlined" style="font-size: 1.3rem;">history</span>
        Event Log
        <span class="badge bg-secondary fw-normal" style="font-size: 0.75rem;"><%= events.length %></span>
    </h5>
    <div class="d-flex align-items-center gap-2">
        <label class="text-body-secondary" style="font-size: 0.85rem;" for="event-type-filter">Filter:</label>
        <select class="form-select form-select-sm" id="event-type-filter" style="width: auto;" data-server-id="<%= server.id %>">
            <option value="">All Events</option>
            <% allTypes.forEach(function(t) { %>
            <option value="<%= t %>" <%= typeFilter === t ? 'selected' : '' %>><%= eventLabels[t] || t %></option>
            <% }) %>
        </select>
        <% if (events.length > 0) { %>
        <form id="clear-events-form" data-server-id="<%= server.id %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-outline-danger btn-sm d-flex align-items-center gap-1">
                <span class="material-icons-outlined" style="font-size: 1rem;">delete_sweep</span> Clear
            </button>
        </form>
        <% } %>
    </div>
</div>

<% if (events.length === 0) { %>
<div class="card">
    <div class="card-body text-center py-5">
        <span class="material-icons-outlined text-body-secondary mb-2" style="font-size: 3rem; opacity: 0.3;">history</span>
        <p class="text-body-secondary mb-0">No events recorded<%= typeFilter ? ' for this filter' : '' %>.</p>
    </div>
</div>
<% } else { %>
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover table-sm mb-0 align-middle">
            <thead>
                <tr>
                    <th style="width: 2.5rem;"></th>
                    <th>Event</th>
                    <th>Details</th>
                    <th style="width: 10rem;">Initiated By</th>
                    <th style="width: 12rem;">Time</th>
                </tr>
            </thead>
            <tbody>
                <% events.forEach(function(event) { %>
                <tr>
                    <% const meta = metaFor(event.type); %>
                    <td class="text-center">
                        <span class="material-icons-outlined <%= meta.color %>" style="font-size: 1.1rem;">
                            <%= meta.icon %>
                        </span>
                    </td>
                    <td>
                        <span class="badge bg-<%= meta.badge %>" style="font-size: 0.75rem;">
                            <%= meta.label || event.type %>
                        </span>
                    </td>
                    <td><%= event.message %></td>
                    <td>
                        <% if (event.initiatedBy && event.initiatedBy !== 'System') { %>
                        <span class="d-flex align-items-center gap-1" style="font-size: 0.85rem;">
                            <span class="material-icons-outlined" style="font-size: 0.9rem;"><%= event.initiatedBy === 'Backup Scheduler' ? 'schedule' : event.initiatedBy === 'Auto Start' ? 'play_circle' : 'person' %></span>
                            <%= event.initiatedBy %>
                        </span>
                        <% } else if (event.playerName) { %>
                        <span class="d-flex align-items-center gap-1" style="font-size: 0.85rem;">
                            <span class="material-icons-outlined" style="font-size: 0.9rem;">sports_esports</span>
                            <%= event.playerName %>
                        </span>
                        <% } else { %>
                        <span class="text-body-secondary" style="font-size: 0.85rem;">System</span>
                        <% } %>
                    </td>
                    <td>
                        <small class="text-body-secondary text-nowrap event-time" data-time="<%= event.createdAt %>"><%= event.createdAt %></small>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% } %>

<!-- Clear Events Confirmation Modal -->
<div class="modal fade" id="clearEventsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-danger">delete_sweep</span>
                    Clear Event Log
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                This will permanently delete all logged events for <strong><%= server.name %></strong>. This cannot be undone.
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm" id="confirm-clear">Clear Events</button>
            </div>
        </div>
    </div>
</div>


<%- include('../partials/foot', { scripts: ['/js/serverState.js', '/js/events.js'] }) %>
