<%- include('../partials/head', { title: server.name + ' | Edit ' + fileName, navbar: true, fluid: true }) %>

<%- include('../partials/serverNav', { server, active: 'files' }) %>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a href="/servers/<%= server.id %>/files" class="d-flex align-items-center gap-1">
                <span class="material-icons-outlined" style="font-size: 1rem;">home</span>
                root
            </a>
        </li>
        <%
        let crumbPath = '';
        breadcrumbs.forEach(function(crumb, i) {
            crumbPath += (crumbPath ? '/' : '') + crumb;
        %>
            <% if (i === breadcrumbs.length - 1) { %>
                <li class="breadcrumb-item active"><%= crumb %></li>
            <% } else { %>
                <li class="breadcrumb-item">
                    <a href="/servers/<%= server.id %>/files/<%= crumbPath %>"><%= crumb %></a>
                </li>
            <% } %>
        <% }) %>
    </ol>
</nav>

<!-- Warning -->
<div class="alert alert-warning d-flex align-items-start gap-2 mb-3">
    <span class="material-icons-outlined mt-1">warning</span>
    <div>
        <strong>Proceed with caution.</strong> Only edit files if you know what you are doing. Incorrect changes can prevent the server from starting or cause data loss.
    </div>
</div>

<!-- Editor -->
<div class="card">
    <div class="card-header d-flex align-items-center gap-2">
        <span class="material-icons-outlined" style="font-size: 1.2rem;">edit_note</span>
        <strong><%= fileName %></strong>
    </div>
    <div class="card-body p-0">
        <form method="POST" action="/servers/<%= server.id %>/edit-file" id="editor-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="filePath" value="<%= filePath %>">
            <textarea name="content" id="file-editor" class="form-control border-0 rounded-0 font-monospace"
                spellcheck="false"
                style="min-height: 500px; resize: vertical; font-size: 0.82rem; line-height: 1.6; background: var(--console-bg, #0d1117); color: var(--console-text, #c9d1d9); tab-size: 4;"><%= content %></textarea>
        </form>
    </div>
</div>

<!-- Actions -->
<div class="d-flex gap-2 mt-3 mb-4">
    <button type="submit" form="editor-form" class="btn btn-success d-flex align-items-center gap-2 flex-grow-1 justify-content-center">
        <span class="material-icons-outlined" style="font-size: 1.2rem;">save</span>
        Save File
    </button>
    <% const parentDir = filePath.split('/').slice(0, -1).join('/'); %>
    <a href="/servers/<%= server.id %>/files<%= parentDir ? '/' + parentDir : '' %>" class="btn btn-outline-secondary d-flex align-items-center gap-2">
        <span class="material-icons-outlined" style="font-size: 1.2rem;">close</span>
        Cancel
    </a>
</div>

<%- include('../partials/foot', { scripts: ['/js/file-editor.js'] }) %>
