<%- include('../partials/head', { title: server.name + ' ' + contentType.label, navbar: true, fluid: true }) %>

<%- include('../partials/serverNav', { server, active: 'plugins' }) %>

<% const _serverStopped = ['stopped', 'crashed'].includes(server.state); %>

<!-- CSRF token for JS fetch calls -->
<input type="hidden" id="csrf-token" value="<%= csrfToken %>">

<% if (!_serverStopped) { %>
<div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
    <span class="material-icons-outlined">warning</span>
    <div>The server must be stopped before uploading or deleting <%= contentType.label.toLowerCase() %>.</div>
</div>
<% } %>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h6 class="text-body-secondary mb-0"><%= files.length %> <%= contentType.label.toLowerCase() %> installed</h6>
    <% if (files.length > 0) { %>
    <div class="d-flex gap-2">
        <a href="/servers/<%= server.id %>/plugins/download-all" class="btn btn-outline-success btn-sm d-flex align-items-center gap-1">
            <span class="material-icons-outlined" style="font-size: 1rem;">download</span>
            Download All
        </a>
        <% if (_serverStopped) { %>
        <button type="button" class="btn btn-outline-danger btn-sm d-flex align-items-center gap-1" id="delete-all-btn">
            <span class="material-icons-outlined" style="font-size: 1rem;">delete_sweep</span>
            Delete All
        </button>
        <% } else { %>
        <button class="btn btn-outline-danger btn-sm d-flex align-items-center gap-1" disabled title="Stop the server to delete">
            <span class="material-icons-outlined" style="font-size: 1rem;">delete_sweep</span>
            Delete All
        </button>
        <% } %>
    </div>
    <% } %>
</div>

<% if (files.length > 0) { %>
<div class="d-flex flex-wrap align-items-center gap-2 mb-3">
    <div class="input-group input-group-sm" style="max-width: 350px;">
        <span class="input-group-text"><span class="material-icons-outlined" style="font-size: 1rem;">search</span></span>
        <input type="text" class="form-control" id="search-input" placeholder="Search <%= contentType.label.toLowerCase() %>...">
    </div>
    <% if (contentType.label === 'Mods') { %>
    <div class="d-flex align-items-center gap-2">
        <label class="text-body-secondary" style="font-size: 0.85rem;" for="env-filter">Filter:</label>
        <select class="form-select form-select-sm" id="env-filter" style="width: auto;">
            <option value="">All Environments</option>
            <option value="both">Client and Server</option>
            <option value="client">Client Only</option>
            <option value="server">Server Only</option>
        </select>
    </div>
    <% } %>
</div>
<% } %>

<!-- Upload -->
<div class="d-flex gap-2 mb-3">
    <% if (_serverStopped) { %>
    <input type="file" class="form-control form-control-sm" id="file-input"
        accept=".jar" multiple style="max-width: 400px;">
    <button type="button" class="btn btn-success btn-sm d-flex align-items-center gap-1 flex-shrink-0"
        id="upload-btn" data-label="<%= contentType.label.toLowerCase() %>" disabled>
        <span class="material-icons-outlined" style="font-size: 1rem;">upload</span>
        Upload
    </button>
    <button type="button" class="btn btn-outline-success btn-sm d-flex align-items-center gap-1 flex-shrink-0"
        id="modrinth-browse-btn">
        <span class="material-icons-outlined" style="font-size: 1rem;">travel_explore</span>
        Browse Modrinth
    </button>
    <% } else { %>
    <input type="file" class="form-control form-control-sm" disabled style="max-width: 400px;">
    <button type="button" class="btn btn-success btn-sm d-flex align-items-center gap-1 flex-shrink-0"
        disabled title="Stop the server to upload">
        <span class="material-icons-outlined" style="font-size: 1rem;">upload</span>
        Upload
    </button>
    <button class="btn btn-outline-success btn-sm d-flex align-items-center gap-1 flex-shrink-0"
        disabled title="Stop the server to install">
        <span class="material-icons-outlined" style="font-size: 1rem;">travel_explore</span>
        Browse Modrinth
    </button>
    <% } %>
</div>

<!-- File listing -->
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th style="width: 40px;"></th>
                    <th>Name</th>
                    <th style="width: 120px;">Size</th>
                    <th style="width: 180px;">Modified</th>
                    <% if (contentType.label === 'Mods') { %>
                    <th style="width: 200px;">Environment</th>
                    <% } %>
                    <th style="width: 90px;"></th>
                </tr>
            </thead>
            <tbody>
                <% files.forEach(function(file) { %>
                <tr data-filename="<%= file.name %>" data-env="<%= file.environment %>">
                    <td>
                        <span class="material-icons-outlined text-body-secondary" style="font-size: 1.2rem;"><%= contentType.icon %></span>
                    </td>
                    <td><%= file.name %></td>
                    <td class="text-body-secondary small"><%= file.sizeFormatted %></td>
                    <td class="text-body-secondary small"><span class="format-date" data-iso="<%= file.modifiedISO %>"></span></td>
                    <% if (contentType.label === 'Mods') { %>
                    <td>
                        <select class="form-select form-select-sm env-select"
                                data-filename="<%= file.name %>"
                                <%= _serverStopped ? '' : 'disabled' %>
                                title="<%= _serverStopped ? 'Change environment' : 'Stop the server to change' %>">
                            <option value="both"   <%= file.environment === 'both'   ? 'selected' : '' %>>Client and Server</option>
                            <option value="client" <%= file.environment === 'client' ? 'selected' : '' %>>Client Only</option>
                            <option value="server" <%= file.environment === 'server' ? 'selected' : '' %>>Server Only</option>
                        </select>
                    </td>
                    <% } %>
                    <td class="text-center">
                        <div class="d-inline-flex gap-1">
                            <a href="/servers/<%= server.id %>/plugins/download?file=<%= encodeURIComponent(file.name) %>"
                               class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center justify-content-center"
                               style="width: 32px; height: 32px; padding: 0;" title="Download">
                                <span class="material-icons-outlined" style="font-size: 1rem;">download</span>
                            </a>
                            <% if (_serverStopped) { %>
                            <button type="button"
                                class="btn btn-outline-danger btn-sm d-inline-flex align-items-center justify-content-center delete-btn"
                                style="width: 32px; height: 32px; padding: 0;" title="Delete"
                                data-filename="<%= file.name %>">
                                <span class="material-icons-outlined" style="font-size: 1rem;">delete</span>
                            </button>
                            <% } else { %>
                            <button class="btn btn-outline-danger btn-sm d-inline-flex align-items-center justify-content-center"
                                style="width: 32px; height: 32px; padding: 0;" disabled title="Stop the server to delete">
                                <span class="material-icons-outlined" style="font-size: 1rem;">delete</span>
                            </button>
                            <% } %>
                        </div>
                    </td>
                </tr>
                <% }) %>
                <% if (files.length === 0) { %>
                <tr>
                    <td colspan="<%= contentType.label === 'Mods' ? 6 : 5 %>" class="text-center text-body-secondary py-4">No <%= contentType.label.toLowerCase() %> installed. Upload some <code>.jar</code> files!</td>
                </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<% if (_serverStopped) { %>
<!-- Drop zone overlay (hidden until drag) -->
<div id="drop-overlay" class="d-none position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
    style="z-index: 1050; background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); pointer-events: none;">
    <div class="text-center">
        <span class="material-icons-outlined text-success" style="font-size: 4rem;">upload_file</span>
        <h4 class="text-white mt-2">Drop .jar files to upload...</h4>
    </div>
</div>
<% } %>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-danger">delete</span>
                    Delete <%= contentType.label === 'Plugins' ? 'Plugin' : 'Mod' %>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Permanently delete "<span id="delete-filename"></span>"?
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm" id="confirm-delete-btn">Delete</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete All Confirmation Modal -->
<div class="modal fade" id="deleteAllModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-danger">delete_sweep</span>
                    Delete All <%= contentType.label %>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Permanently delete all <strong><%= files.length %></strong> <%= contentType.label.toLowerCase() %>? This cannot be undone.
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm" id="confirm-delete-all-btn">Delete All</button>
            </div>
        </div>
    </div>
</div>


<!-- Browse Modrinth Modal -->
<div class="modal fade" id="modrinthModal" tabindex="-1" aria-hidden="true"
    data-server-type="<%= server.serverType %>" data-server-version="<%= server.version %>">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-success">travel_explore</span>
                    Browse <%= contentType.label %> on Modrinth
                    <small class="text-body-secondary fw-normal" style="font-size: 0.8rem;">
                        Compatible with <%= (server.serverType || '').charAt(0).toUpperCase() + (server.serverType || '').slice(1) %> <%= server.version %>
                    </small>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                    <div class="input-group input-group-sm" style="max-width: 350px;">
                        <span class="input-group-text"><span class="material-icons-outlined" style="font-size: 1rem;">search</span></span>
                        <input type="text" class="form-control" id="modrinth-search"
                            placeholder="Search <%= contentType.label.toLowerCase() %> on Modrinth...">
                    </div>
                    <select class="form-select form-select-sm" id="modrinth-sort" style="width: auto;" title="Sort by">
                        <option value="relevance" selected>Relevance</option>
                        <option value="downloads">Downloads</option>
                        <option value="newest">Newest</option>
                        <option value="updated">Updated</option>
                    </select>
                </div>
                <div class="text-center py-4 d-none" id="modrinth-loading">
                    <div class="spinner-border text-success" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
                <div class="text-center py-4 d-none" id="modrinth-empty">
                    <span class="material-icons-outlined text-body-secondary mb-2" style="font-size: 4rem;">extension_off</span>
                    <h5 class="text-body-secondary">No compatible <%= contentType.label.toLowerCase() %> found</h5>
                    <p class="text-body-secondary mb-0">Try a different search.</p>
                </div>
                <div class="table-responsive d-none" id="modrinth-results-wrap">
                    <table class="table table-hover mb-0 align-middle">
                        <tbody id="modrinth-results"></tbody>
                    </table>
                </div>
                <button type="button" class="btn btn-outline-secondary btn-sm w-100 mt-2 d-none" id="modrinth-load-more">
                    Load more
                </button>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/foot', { scripts: ['/js/serverState.js', '/js/plugins.js'] }) %>
