<%- include('../partials/head', { title: server.name + ' Settings', navbar: true, fluid: true }) %>

<%- include('../partials/serverNav', { server, active: 'settings' }) %>

<%
const _displayVersion = (server.serverType || 'vanilla') === 'custom'
    ? '(Unknown Version)'
    : (server.version || '(Unknown Version)');
%>

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-6">
        <div class="alert alert-info d-flex align-items-center gap-2 mb-3">
            <span class="material-icons-outlined">info</span>
            Changes take effect on next server restart.
        </div>

        <div class="card">
            <div class="card-body p-4">
                <form method="POST" action="/servers/<%= server.id %>/edit" novalidate>
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <div class="mb-3">
                        <label for="name" class="form-label required-star">Server Name</label>
                        <input type="text" class="form-control" id="name" name="name" required
                            minlength="1" maxlength="50" pattern="[a-zA-Z0-9 _\-]+"
                            value="<%= server.name %>">
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Server Type</label>
                            <input type="text" class="form-control" value="<%= (server.serverType || 'vanilla').charAt(0).toUpperCase() + (server.serverType || 'vanilla').slice(1) %>" disabled>
                        </div>
                        <div class="col-md-4 mt-3 mt-md-0">
                            <label class="form-label">Version</label>
                            <input type="text" class="form-control" value="<%= _displayVersion %>" disabled>
                            <div class="form-text">Type and version cannot be changed.</div>
                        </div>
                        <div class="col-md-4 mt-3 mt-md-0">
                            <label for="port" class="form-label required-star">Server Port</label>
                            <input type="number" class="form-control" id="port" name="port"
                                value="<%= server.port %>" min="1024" max="65535" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label for="gamemode" class="form-label">Game Mode</label>
                            <select class="form-select" id="gamemode" name="gamemode">
                                <option value="survival" <%= server.gamemode === 'survival' ? 'selected' : '' %>>Survival</option>
                                <option value="creative" <%= server.gamemode === 'creative' ? 'selected' : '' %>>Creative</option>
                                <option value="adventure" <%= server.gamemode === 'adventure' ? 'selected' : '' %>>Adventure</option>
                                <option value="spectator" <%= server.gamemode === 'spectator' ? 'selected' : '' %>>Spectator</option>
                            </select>
                        </div>
                        <div class="col-md-4 mt-3 mt-md-0">
                            <label for="difficulty" class="form-label">Difficulty</label>
                            <select class="form-select" id="difficulty" name="difficulty">
                                <option value="peaceful" <%= server.difficulty === 'peaceful' ? 'selected' : '' %>>Peaceful</option>
                                <option value="easy" <%= server.difficulty === 'easy' ? 'selected' : '' %>>Easy</option>
                                <option value="normal" <%= server.difficulty === 'normal' ? 'selected' : '' %>>Normal</option>
                                <option value="hard" <%= server.difficulty === 'hard' ? 'selected' : '' %>>Hard</option>
                            </select>
                        </div>
                        <div class="col-md-4 mt-3 mt-md-0">
                            <label for="seed" class="form-label">World Seed</label>
                            <input type="text" class="form-control" id="seed" name="seed"
                                value="<%= server.seed || '' %>" placeholder="Optional">
                        </div>
                    </div>

                    <!-- Advanced Options -->
                    <div class="mb-3 text-center">
                        <a class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1 advanced-toggle"
                           data-bs-toggle="collapse" href="#advancedOptions" role="button" aria-expanded="false">
                            <span class="material-icons-outlined" style="font-size: 1rem;">tune</span>
                            Advanced Options
                            <span class="material-icons-outlined advanced-arrow" style="font-size: 1rem;">expand_more</span>
                        </a>
                        <div class="collapse mt-3" id="advancedOptions">
                            <div class="row">
                                <div class="col-md-6">
                                    <label for="memory" class="form-label required-star">Memory (MB)</label>
                                    <input type="number" class="form-control" id="memory" name="memory"
                                        value="<%= server.memory %>" min="512" max="65536" step="256" required>
                                    <div class="form-text">RAM allocated to the server (-Xmx).</div>
                                </div>
                                <div class="col-md-6 mt-3 mt-md-0">
                                    <label for="javaArgs" class="form-label">Additional JVM Arguments</label>
                                    <input type="text" class="form-control" id="javaArgs" name="javaArgs"
                                        value="<%= server.javaArgs || '' %>" placeholder="-XX:+UseG1GC">
                                    <div class="form-text">Optional. Extra Java flags.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <button type="submit" class="btn btn-success w-100 d-flex align-items-center justify-content-center gap-2" data-validate-required>
                        <span class="material-icons-outlined" style="font-size: 1.2rem;">save</span>
                        Save Changes
                    </button>
                </form>
            </div>
        </div>

        <!-- Server Behavior -->
        <div class="card mt-3">
            <div class="card-body p-4">
                <h6 class="mb-3">Server Behavior</h6>
                <div class="form-check form-switch mb-2">
                    <input class="form-check-input toggle-switch" type="checkbox" id="autoRestart"
                        data-server-id="<%= server.id %>" data-csrf="<%= csrfToken %>"
                        data-endpoint="autorestart"
                        <%= server.autoRestart ? 'checked' : '' %>>
                    <label class="form-check-label" for="autoRestart">Auto-restart on crash</label>
                </div>
                <div class="form-check form-switch">
                    <input class="form-check-input toggle-switch" type="checkbox" id="autoStart"
                        data-server-id="<%= server.id %>" data-csrf="<%= csrfToken %>"
                        data-endpoint="autostart"
                        <%= server.autoStart ? 'checked' : '' %>>
                    <label class="form-check-label" for="autoStart">Start with Craftbox</label>
                </div>
                <hr class="my-3">
                <h6 class="mb-2">Status Page</h6>
                <div class="form-check form-switch mb-1">
                    <input class="form-check-input toggle-switch" type="checkbox" id="statusPagePublic"
                        data-server-id="<%= server.id %>" data-csrf="<%= csrfToken %>"
                        data-endpoint="statuspublic"
                        <%= server.statusPagePublic ? 'checked' : '' %>>
                    <label class="form-check-label" for="statusPagePublic">
                        Status Page Visibility: <strong id="statusPageLabel"><%= server.statusPagePublic ? 'Public' : 'Unlisted' %></strong>
                    </label>
                </div>
                <small class="text-body-secondary d-block">
                    <strong>Public</strong>: Server appears on the <a href="/status" target="_blank">/status</a> page for anyone to see.<br>
                    <strong>Unlisted</strong> (default): Only accessible via its <a href="/status/<%= server.id %>" target="_blank">direct link</a>.
                </small>
            </div>
        </div>

        <!-- Update Checker -->
        <% if ((server.serverType || 'vanilla') !== 'custom') { %>
        <div class="card mt-3">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="mb-1">Server Jar Updates</h6>
                        <small class="text-body-secondary" id="update-status">
                            <% if (server.build) { %>
                                Current build: #<%= server.build %>
                            <% } else { %>
                                No build number recorded.
                            <% } %>
                        </small>
                    </div>
                    <div class="d-flex gap-2" id="update-actions">
                        <button type="button" class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-1"
                            id="check-update-btn" data-server-id="<%= server.id %>">
                            <span class="material-icons-outlined" style="font-size: 1rem;">refresh</span>
                            Check for Updates
                        </button>
                    </div>
                </div>
                <div id="update-result" class="d-none mt-2"></div>
            </div>
        </div>
        <% } %>
        <% const _serverStopped = ['stopped', 'crashed'].includes(server.state); %>

        <!-- Duplicate Server -->
        <div class="card mt-3">
            <div class="card-body p-4">
                <h6 class="mb-3 d-flex align-items-center gap-2">
                    <span class="material-icons-outlined" style="font-size: 1.2rem;">content_copy</span>
                    Duplicate Server
                </h6>
                <form id="duplicate-form" method="POST" action="/servers/<%= server.id %>/duplicate">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="stopFirst" id="dup-stop-first" value="false">
                    <input type="hidden" name="startAfter" id="dup-start-after" value="true">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="dup-name" class="form-label required-star">New Server Name</label>
                            <input type="text" class="form-control" id="dup-name" name="name"
                                value="<%= server.name %> - Copy" minlength="1" maxlength="50"
                                pattern="[a-zA-Z0-9 _\-]+" required>
                        </div>
                        <div class="col-md-6 mt-3 mt-md-0">
                            <label for="dup-port" class="form-label required-star">New Port</label>
                            <input type="number" class="form-control" id="dup-port" name="port"
                                value="<%= server.port + 1 %>" min="1024" max="65535" required>
                        </div>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="includeWorld" name="includeWorld" value="true" checked>
                        <label class="form-check-label" for="includeWorld">Include world data</label>
                        <div class="form-text">Uncheck to copy only configuration and mods/plugins (no world data).</div>
                    </div>
                    <% if (_serverStopped) { %>
                    <button type="submit" class="btn btn-outline-secondary d-flex align-items-center gap-1">
                        <span class="material-icons-outlined" style="font-size: 1rem;">content_copy</span>
                        Duplicate
                    </button>
                    <% } else { %>
                    <button type="button" class="btn btn-outline-secondary d-flex align-items-center gap-1" id="duplicate-running-btn">
                        <span class="material-icons-outlined" style="font-size: 1rem;">content_copy</span>
                        Duplicate
                    </button>
                    <% } %>
                </form>
            </div>
        </div>

        <!-- Save as Template -->
        <div class="card mt-3">
            <div class="card-body p-4">
                <h6 class="mb-3 d-flex align-items-center gap-2">
                    <span class="material-icons-outlined" style="font-size: 1.2rem;">bookmark_add</span>
                    Save as Template
                </h6>
                <p class="text-body-secondary mb-2" style="font-size: 0.85rem;">
                    Save this server's settings as a reusable template for creating new servers.
                </p>
                <div class="mb-3 text-body-secondary" style="font-size: 0.8rem;">
                    <div class="mb-2">
                        <span class="material-icons-outlined align-middle text-success" style="font-size: 0.9rem;">check_circle</span>
                        <strong class="fw-semibold">Included:</strong>
                        Server type & version, memory & JVM args, game mode & difficulty, port & behavior flags
                    </div>
                    <div>
                        <span class="material-icons-outlined align-middle text-danger" style="font-size: 0.9rem;">cancel</span>
                        <strong class="fw-semibold">Not included:</strong>
                        World data & files, mods & plugins, server.properties, backup schedules
                    </div>
                </div>
                <form id="template-form" method="POST" action="/templates/create">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="serverId" value="<%= server.id %>">
                    <input type="hidden" name="stopFirst" id="tmpl-stop-first" value="false">
                    <input type="hidden" name="startAfter" id="tmpl-start-after" value="true">
                    <div class="mb-3">
                        <label for="template-name" class="form-label required-star">Template Name</label>
                        <input type="text" class="form-control" id="template-name" name="name"
                            value="<%= server.name %>" minlength="1" maxlength="50"
                            pattern="[a-zA-Z0-9 _\-]+" required>
                    </div>
                    <% if (_serverStopped) { %>
                    <button type="submit" class="btn btn-outline-secondary d-flex align-items-center gap-1">
                        <span class="material-icons-outlined" style="font-size: 1rem;">bookmark_add</span>
                        Save Template
                    </button>
                    <% } else { %>
                    <button type="button" class="btn btn-outline-secondary d-flex align-items-center gap-1" id="template-running-btn">
                        <span class="material-icons-outlined" style="font-size: 1rem;">bookmark_add</span>
                        Save Template
                    </button>
                    <% } %>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Stop & Duplicate Modal -->
<div class="modal fade" id="stopDuplicateModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-warning">warning</span>
                    Server Running
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>The server must be stopped to duplicate. Stop the server and duplicate?</p>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="dupStartAfter" checked>
                    <label class="form-check-label" for="dupStartAfter">Start server after duplicate</label>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning btn-sm" id="confirm-stop-duplicate-btn">Stop & Duplicate</button>
            </div>
        </div>
    </div>
</div>

<!-- Stop & Save Template Modal -->
<div class="modal fade" id="stopTemplateModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-warning">warning</span>
                    Server Running
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>The server must be stopped to save a template. Stop the server and save the template?</p>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="tmplStartAfter" checked>
                    <label class="form-check-label" for="tmplStartAfter">Start server after saving</label>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning btn-sm" id="confirm-stop-template-btn">Stop & Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Restart Required Modal -->
<div class="modal fade" id="restartModal" tabindex="-1" data-server-state="<%= server.state %>">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-info">restart_alt</span>
                    Restart Required
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Settings have been saved. The server must be restarted for changes to take effect.
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Later</button>
                <button type="button" class="btn btn-info btn-sm" id="restart-now-btn"
                    data-server-id="<%= server.id %>" data-csrf="<%= csrfToken %>">Restart Now</button>
            </div>
        </div>
    </div>
</div>


<%- include('../partials/foot', { scripts: ['/js/edit.js', '/js/restart-modal.js'] }) %>
