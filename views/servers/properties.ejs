<%- include('../partials/head', { title: server.name + ' Properties', navbar: true, fluid: true }) %>

<%- include('../partials/serverNav', { server, active: 'properties' }) %>

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-8">
        <% if (Object.keys(properties).length === 0) { %>
        <div class="text-center py-5">
            <span class="material-icons-outlined text-body-secondary mb-3" style="font-size: 4rem;">tune</span>
            <h5 class="text-body-secondary">No properties to edit</h5>
            <p class="text-body-secondary mb-0">This server has no readable <code>server.properties</code> file yet.</p>
        </div>
        <% } else { %>
        <div class="alert alert-info d-flex align-items-center gap-2 mb-3">
            <span class="material-icons-outlined">info</span>
            Changes take effect on next server restart.
        </div>

        <form id="properties-form" data-server-id="<%= server.id %>" novalidate>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <% groups.forEach(function(group) { %>
                <% const groupProps = Object.entries(propertyMeta).filter(function([k, m]) { return m.group === group.id && properties[k] !== undefined; }); %>
                <% if (groupProps.length > 0) { %>
                <div class="card mb-3">
                    <div class="card-header d-flex align-items-center gap-2">
                        <span class="material-icons-outlined" style="font-size: 1.2rem;"><%= group.icon %></span>
                        <strong><%= group.label %></strong>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <% groupProps.forEach(function([key, meta]) { %>
                                <div class="col-md-6 col-lg-4">
                                    <% if (meta.type === 'boolean') { %>
                                        <label class="form-label d-block"><%= meta.label %></label>
                                        <div class="form-check form-switch mb-0">
                                            <input class="form-check-input prop-toggle" type="checkbox"
                                                id="prop_<%= key %>" name="<%= key %>" value="true"
                                                <%= properties[key] === 'true' ? 'checked' : '' %>>
                                            <label class="form-check-label text-body-secondary small prop-toggle-label" for="prop_<%= key %>"><%= properties[key] === 'true' ? 'Enabled' : 'Disabled' %></label>
                                        </div>
                                        <% if (meta.description) { %>
                                            <div class="form-text"><%= meta.description %></div>
                                        <% } %>
                                    <% } else if (meta.type === 'enum') { %>
                                        <label for="prop_<%= key %>" class="form-label"><%= meta.label %></label>
                                        <select class="form-select form-select-sm" id="prop_<%= key %>" name="<%= key %>">
                                            <% meta.options.forEach(function(opt) { %>
                                                <option value="<%= opt.value %>" <%= properties[key] === opt.value ? 'selected' : '' %>><%= opt.label %></option>
                                            <% }) %>
                                        </select>
                                        <% if (meta.description) { %>
                                            <div class="form-text"><%= meta.description %></div>
                                        <% } %>
                                    <% } else if (meta.type === 'number') { %>
                                        <label for="prop_<%= key %>" class="form-label"><%= meta.label %></label>
                                        <input type="number" class="form-control form-control-sm"
                                            id="prop_<%= key %>" name="<%= key %>"
                                            value="<%= properties[key] %>"
                                            <% if (meta.min !== undefined) { %>min="<%= meta.min %>"<% } %>
                                            <% if (meta.max !== undefined) { %>max="<%= meta.max %>"<% } %>>
                                        <% if (meta.description) { %>
                                            <div class="form-text"><%= meta.description %></div>
                                        <% } %>
                                    <% } else { %>
                                        <label for="prop_<%= key %>" class="form-label"><%= meta.label %></label>
                                        <input type="text" class="form-control form-control-sm"
                                            id="prop_<%= key %>" name="<%= key %>"
                                            value="<%= properties[key] %>">
                                        <% if (meta.description) { %>
                                            <div class="form-text"><%= meta.description %></div>
                                        <% } %>
                                    <% } %>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
                <% } %>
            <% }) %>

            <%
            const knownKeys = Object.keys(propertyMeta);
            const unknownProps = Object.entries(properties).filter(function([k]) { return !knownKeys.includes(k); });
            %>
            <% if (unknownProps.length > 0) { %>
            <div class="card mb-3">
                <div class="card-header d-flex align-items-center gap-2">
                    <span class="material-icons-outlined" style="font-size: 1.2rem;">help_outline</span>
                    <strong>Other</strong>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <% unknownProps.forEach(function([key, value]) { %>
                            <div class="col-md-6 col-lg-4">
                                <label for="prop_<%= key %>" class="form-label"><%= key %></label>
                                <input type="text" class="form-control form-control-sm"
                                    id="prop_<%= key %>" name="<%= key %>"
                                    value="<%= value %>">
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
            <% } %>

            <button type="submit" class="btn btn-success w-100 d-flex align-items-center justify-content-center gap-2 mb-4">
                <span class="material-icons-outlined" style="font-size: 1.2rem;">save</span>
                Save Properties
            </button>
        </form>
        <% } %>
    </div>
</div>

<!-- Restart Required Modal -->
<div class="modal fade" id="restartModal" tabindex="-1" data-server-state="<%= server.state %>">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-info">restart_alt</span>
                    Restart Required
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Properties have been saved. The server must be restarted for changes to take effect.
                <div class="form-check mt-3">
                    <input class="form-check-input" type="checkbox" id="restartBackup">
                    <label class="form-check-label" for="restartBackup">Create backup before restarting</label>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Later</button>
                <button type="button" class="btn btn-info btn-sm" id="restart-now-btn"
                    data-server-id="<%= server.id %>">Restart Now</button>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/foot', { scripts: ['/js/serverState.js', '/js/properties.js', '/js/restart-modal.js'] }) %>
