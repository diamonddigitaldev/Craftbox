<%- include('../partials/head', { title: 'Create Server' , navbar: true }) %>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-6">
            <div class="d-flex align-items-center gap-2 mb-4">
                <a href="/dashboard" class="btn btn-outline-secondary btn-sm d-flex align-items-center">
                    <span class="material-icons-outlined" style="font-size: 1.2rem;">arrow_back</span>
                </a>
                <h4 class="mb-0">Create New Server</h4>
            </div>

            <div class="card">
                <div class="card-body p-4">
                    <form id="create-server-form">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="serverType" id="serverType" value="vanilla">

                        <!-- Create source: template / modpack (neither = from scratch) -->
                        <div class="mb-4" id="create-source-group">
                            <label class="form-label">Quick Start (Optional)</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <div class="card type-card text-center p-2"
                                        id="source-modpack-card" data-source="modpack" role="button">
                                        <span class="material-icons-outlined mb-1" style="font-size: 2rem;">widgets</span>
                                        <div class="small fw-semibold">Modpack</div>
                                        <div class="text-body-secondary" style="font-size: 0.7rem;">Install a Modrinth modpack</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="card type-card text-center p-2 type-card-disabled"
                                        id="source-template-card" data-source="template" role="button"
                                        title="No templates saved yet">
                                        <span class="material-icons-outlined mb-1" style="font-size: 2rem;">bookmark</span>
                                        <div class="small fw-semibold">Template</div>
                                        <div class="text-body-secondary" style="font-size: 0.7rem;">Start from a saved template</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Load from Template (shown for the Template source) -->
                        <div class="mb-4 d-none" id="template-group">
                            <label for="template-select" class="form-label">Load from Template</label>
                            <select class="form-select" id="template-select">
                                <option value="">None — start from scratch</option>
                            </select>
                        </div>

                        <!-- Modpack summary (replaces type/version selection when
                             creating from a Modrinth modpack or local .mrpack) -->
                        <div class="mb-4 d-none" id="modpack-summary">
                            <label class="form-label">Modpack</label>
                            <div class="card">
                                <div class="card-body d-flex align-items-center gap-3 p-3">
                                    <img src="" alt="" class="modpack-icon d-none" id="modpack-icon">
                                    <span class="modpack-icon modpack-icon-placeholder" id="modpack-icon-placeholder">
                                        <span class="material-icons-outlined">widgets</span>
                                    </span>
                                    <div class="overflow-hidden flex-grow-1">
                                        <div class="fw-semibold text-truncate" id="modpack-title">Loading modpack...</div>
                                        <small class="text-body-secondary d-block text-truncate" id="modpack-subtitle"></small>
                                    </div>
                                    <div class="d-none d-sm-flex gap-1" id="modpack-badges"></div>
                                    <button type="button" class="btn-close flex-shrink-0" id="modpack-clear"
                                        title="Choose a different setup"></button>
                                </div>
                            </div>
                            <div class="form-text">The mod loader, Minecraft version, and mods come from the modpack.</div>
                            <input type="hidden" id="modpackProject">
                            <input type="hidden" id="modpackVersion">
                        </div>

                        <!-- Local .mrpack upload (shown for the Modpack source) -->
                        <div class="mb-4 d-none" id="mrpack-file-group">
                            <label for="mrpack-file" class="form-label required-star">Modpack File (.mrpack)</label>
                            <input type="file" class="form-control" id="mrpack-file" accept=".mrpack">
                            <div class="form-text">A Modrinth modpack file. The mod loader and mods are installed from it.</div>
                            <div class="d-flex align-items-center gap-3 mt-3">
                                <hr class="flex-grow-1 my-0">
                                <span class="text-body-secondary small">or</span>
                                <hr class="flex-grow-1 my-0">
                            </div>
                            <a href="/modpacks"
                                class="btn btn-outline-success w-100 d-flex align-items-center justify-content-center gap-2 mt-3">
                                <span class="material-icons-outlined" style="font-size: 1.2rem;">travel_explore</span>
                                Browse Modpacks on Modrinth
                            </a>
                        </div>

                        <!-- Server Type Selection -->
                        <div class="mb-4" id="type-select-group">
                            <label class="form-label">Server Type</label>
                            <div class="row g-2" id="type-selector">
                                <div class="col-12 text-center text-body-secondary py-3">
                                    <div class="spinner-border spinner-border-sm" role="status"></div>
                                    Loading server types...
                                </div>
                            </div>
                            <div class="alert alert-warning d-none align-items-start gap-2 mt-3 mb-0"
                                id="custom-type-notice">
                                <span class="material-icons-outlined">warning</span>
                                <div>
                                    <div class="small">
                                        Craftbox cannot identify the contents of an arbitrary JAR, so some features
                                        may be unavailable or behave unexpectedly:
                                    </div>
                                    <ul class="small mb-0 mt-1 ps-3">
                                        <li>Version tracking and update checks</li>
                                        <li>Server properties management</li>
                                        <li>Plugin and mod management</li>
                                        <li>Any tooling that depends on knowing the underlying server type</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="name" class="form-label required-star">Server Name</label>
                            <input type="text" class="form-control" id="name" name="name" required minlength="1"
                                maxlength="50" pattern="[a-zA-Z0-9 _\-]+" placeholder="My Minecraft Server" autofocus>
                            <div class="form-text">1-50 characters. Letters, numbers, spaces, hyphens, underscores.
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6" id="version-group">
                                <label for="version-display" class="form-label required-star">Version</label>
                                <div class="input-group">
                                    <input type="text" class="form-control" id="version-display" readonly required
                                        placeholder="Loading versions...">
                                    <button class="btn btn-outline-secondary d-flex align-items-center" type="button"
                                        id="version-browse-btn">
                                        <span class="material-icons-outlined"
                                            style="font-size: 1.2rem;">manage_search</span>
                                    </button>
                                </div>
                                <input type="hidden" name="version" id="version">
                            </div>
                            <!-- Custom JAR URL input (hidden by default) -->
                            <div class="col-md-6 d-none" id="custom-url-group">
                                <label for="customJarUrl" class="form-label required-star">Jar Download URL</label>
                                <input type="url" class="form-control" id="customJarUrl" name="customJarUrl"
                                    placeholder="https://example.com/server.jar">
                                <div class="form-text">Direct download link to a .jar file.</div>
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label for="port" class="form-label required-star">Server Port</label>
                                <input type="number" class="form-control" id="port" name="port" value="25565" min="1024"
                                    max="65535" required>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label for="gamemode" class="form-label">Game Mode</label>
                                <select class="form-select" id="gamemode" name="gamemode">
                                    <option value="survival" selected>Survival</option>
                                    <option value="creative">Creative</option>
                                    <option value="adventure">Adventure</option>
                                    <option value="spectator">Spectator</option>
                                </select>
                            </div>
                            <div class="col-md-4 mt-3 mt-md-0">
                                <label for="difficulty" class="form-label">Difficulty</label>
                                <select class="form-select" id="difficulty" name="difficulty">
                                    <option value="peaceful">Peaceful</option>
                                    <option value="easy" selected>Easy</option>
                                    <option value="normal">Normal</option>
                                    <option value="hard">Hard</option>
                                </select>
                            </div>
                            <div class="col-md-4 mt-3 mt-md-0">
                                <label for="seed" class="form-label">World Seed</label>
                                <input type="text" class="form-control" id="seed" name="seed" placeholder="Optional">
                            </div>
                        </div>

                        <!-- Advanced Options -->
                        <div class="mb-3 text-center">
                            <a class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1 advanced-toggle"
                                data-bs-toggle="collapse" href="#advancedOptions" role="button" aria-expanded="false">
                                <span class="material-icons-outlined" style="font-size: 1rem;">tune</span>
                                Advanced Options
                                <span class="material-icons-outlined advanced-arrow"
                                    style="font-size: 1rem;">expand_more</span>
                            </a>
                            <div class="collapse mt-3" id="advancedOptions">
                                <div class="row">
                                    <div class="col-md-6">
                                        <label for="memory" class="form-label required-star">Memory (MB)</label>
                                        <input type="number" class="form-control" id="memory" name="memory" value="2048"
                                            min="512" max="65536" step="1" required>
                                        <div class="form-text">RAM allocated to the server (-Xmx).</div>
                                    </div>
                                    <div class="col-md-6 mt-3 mt-md-0">
                                        <label for="javaArgs" class="form-label">Additional JVM Arguments</label>
                                        <input type="text" class="form-control" id="javaArgs" name="javaArgs"
                                            placeholder="-XX:+UseG1GC">
                                        <div class="form-text">Optional. Extra Java flags.</div>
                                    </div>
                                </div>
                                <div class="row mt-3">
                                    <div class="col-md-6">
                                        <label for="group" class="form-label">Assign Group</label>
                                        <div class="group-picker-wrap">
                                            <input type="text" class="form-control" id="group" name="group"
                                                maxlength="50" pattern="[a-zA-Z0-9 _\-]+" placeholder="Optional"
                                                autocomplete="off" data-group-picker
                                                data-groups="<%= JSON.stringify(typeof groupNames !== 'undefined' ? groupNames : []) %>">
                                            <div class="list-group group-picker-list group-picker-inline d-none"></div>
                                        </div>
                                        <div class="form-text">1-50 characters. Letters, numbers, spaces, hyphens, underscores.</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="form-check mb-4">
                            <input class="form-check-input" type="checkbox" id="eula" name="eula" required>
                            <label class="form-check-label required-star" for="eula">
                                I agree to the <a href="https://aka.ms/MinecraftEULA" target="_blank"
                                    rel="noopener noreferrer">Minecraft End User License Agreement</a>
                            </label>
                            <div class="form-text">You must accept the EULA before creating a server.</div>
                        </div>

                        <button type="submit"
                            class="btn btn-success w-100 d-flex align-items-center justify-content-center gap-2"
                            id="create-btn" disabled>
                            <span class="material-icons-outlined" style="font-size: 1.2rem;">add</span>
                            Create Server
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>


    <%- include('../partials/version-picker-modal') %>

    <%- include('../partials/foot', { scripts: ['/js/version-picker.js', '/js/create.js', '/js/group-picker.js'] }) %>