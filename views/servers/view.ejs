<%- include('../partials/head', { title: server.name + ' Console', navbar: true, fluid: true }) %>

<%- include('../partials/serverNav', { server, active: 'console' }) %>

<!-- Action Buttons -->
<input type="hidden" name="_csrf" value="<%= csrfToken %>">
<div class="d-flex flex-column flex-md-row gap-2 mb-3" id="server-controls" data-server-id="<%= server.id %>">
    <div class="d-flex flex-wrap gap-2">
        <button type="button" class="btn btn-success btn-sm d-flex align-items-center gap-1 server-action-btn" data-action="start"
            <%= !['stopped', 'crashed'].includes(server.state) ? 'disabled' : '' %>>
            <span class="material-icons-outlined" style="font-size: 1rem;">play_arrow</span> Start
        </button>
        <button type="button" class="btn btn-warning btn-sm d-flex align-items-center gap-1 server-action-btn" data-action="stop"
            <%= !['running', 'starting'].includes(server.state) ? 'disabled' : '' %>>
            <span class="material-icons-outlined" style="font-size: 1rem;">stop</span> Stop
        </button>
        <button type="button" class="btn btn-info btn-sm d-flex align-items-center gap-1 server-action-btn" data-action="restart"
            <%= server.state !== 'running' ? 'disabled' : '' %>>
            <span class="material-icons-outlined" style="font-size: 1rem;">restart_alt</span> Restart
        </button>
        <button type="button" class="btn btn-outline-danger btn-sm d-flex align-items-center gap-1 server-action-btn" data-action="kill"
            <%= !['running', 'starting', 'stopping'].includes(server.state) ? 'disabled' : '' %>>
            <span class="material-icons-outlined" style="font-size: 1rem;">dangerous</span> Kill
        </button>
    </div>

    <div class="d-flex flex-wrap gap-2 align-items-center ms-md-auto">
        <div class="form-check form-switch d-flex align-items-center gap-2 mb-0">
            <input class="form-check-input" type="checkbox" id="autoRestart"
                <%= server.autoRestart ? 'checked' : '' %>>
            <label class="form-check-label small" for="autoRestart">Auto-restart</label>
        </div>
        <div class="form-check form-switch d-flex align-items-center gap-2 mb-0">
            <input class="form-check-input" type="checkbox" id="autoStart"
                <%= server.autoStart ? 'checked' : '' %>>
            <label class="form-check-label small" for="autoStart">Auto-start</label>
        </div>
        <button type="button" class="btn btn-outline-danger btn-sm d-flex align-items-center gap-1 server-action-btn" data-action="delete"
            <%= !['stopped', 'crashed'].includes(server.state) ? 'disabled' : '' %>>
            <span class="material-icons-outlined" style="font-size: 1rem;">delete</span> Delete
        </button>
    </div>
</div>

<div class="alert alert-danger align-items-center gap-2 mb-3" id="crash-banner"
     style="display: <%= (server.state === 'crashed' && !server.provisionFailed) ? 'flex' : 'none' %>;">
    <span class="material-icons-outlined">error</span>
    <div id="crash-banner-text">
        <% if (server.crashReason && (server.crashReason.startsWith('Provisioning failed') || server.crashReason.startsWith('Duplication failed') || server.crashReason.startsWith('Jar upgrade interrupted') || server.crashReason.startsWith('Provisioning interrupted') || server.crashReason.startsWith('Modpack install failed'))) { %>
            <%= server.crashReason %>
        <% } else { %>
            Server crashed<%= server.crashReason === 'oom' ? ' due to Out of Memory' : '' %>.
            Exit code: <strong><%= server.exitCode != null ? server.exitCode : '' %></strong>.
            <% if (server.autoRestart) { %>Auto-restart is enabled.<% } %>
        <% } %>
    </div>
</div>

<div class="alert alert-info align-items-center gap-2 mb-3" id="operation-banner"
     style="display: <%= ['provisioning', 'upgrading_jar', 'backing_up', 'restoring'].includes(server.state) ? 'flex' : 'none' %>;">
    <span class="spinner-border spinner-border-sm" role="status"></span>
    <div id="operation-banner-text">
        <% if (server.state === 'provisioning') { %>
            Server setup in progress...
        <% } else if (server.state === 'upgrading_jar') { %>
            Server upgrade in progress...
        <% } else if (server.state === 'backing_up') { %>
            Creating a backup of the server files...
        <% } else if (server.state === 'restoring') { %>
            Restoring server files from a backup...
        <% } %>
    </div>
</div>

<!-- Resource Stats Bar -->
<div class="d-flex flex-wrap gap-3 mb-3 text-body-secondary" style="font-size: 0.85rem;" id="stats-bar" data-server-id="<%= server.id %>">
    <span class="d-flex align-items-center gap-1">
        <span class="material-icons-outlined" style="font-size: 1rem;">people</span>
        <span id="stat-players">0</span> online
    </span>
    <span class="d-flex align-items-center gap-1">
        <span class="material-icons-outlined" style="font-size: 1rem;">schedule</span>
        <span id="stat-uptime">--</span>
    </span>
    <span class="d-flex align-items-center gap-1">
        <span class="material-icons-outlined" style="font-size: 1rem;">speed</span>
        <span id="stat-cpu">--</span>
    </span>
    <span class="d-flex align-items-center gap-1">
        <span class="material-icons-outlined" style="font-size: 1rem;">memory</span>
        <span id="stat-memory">--</span>
    </span>
    <span class="d-flex align-items-center gap-1">
        <span class="material-icons-outlined" style="font-size: 1rem;">storage</span>
        <span id="stat-disk">--</span>
    </span>
</div>

<!-- Console -->
<div data-server-id="<%= server.id %>" data-server-state="<%= server.state %>" id="console-wrapper"
     data-memory-allocated="<%= server.memory || 2048 %>">
    <%- include('../partials/console', { server }) %>
</div>

<!-- Resource Usage Graphs -->
<div class="mt-3 d-flex flex-column gap-3" id="resource-graphs">
    <div class="card">
        <div class="card-body p-3">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <span class="fw-semibold text-body-secondary d-flex align-items-center gap-1" style="font-size: 0.9rem;">
                    <span class="material-icons-outlined" style="font-size: 1.15rem;">speed</span>
                    CPU Usage
                </span>
                <span class="fw-semibold" style="font-size: 0.9rem;" id="cpu-label">--</span>
            </div>
            <div style="position: relative; height: 160px;">
                <canvas id="cpu-chart"></canvas>
                <div class="chart-offline-overlay text-body-secondary" id="cpu-offline"
                    style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:0.85rem;<%= server.state === 'running' ? 'display:none;' : '' %>">
                    No Data — Server Offline
                </div>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="card-body p-3">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <span class="fw-semibold text-body-secondary d-flex align-items-center gap-1" style="font-size: 0.9rem;">
                    <span class="material-icons-outlined" style="font-size: 1.15rem;">memory</span>
                    RAM Usage
                </span>
                <span class="fw-semibold" style="font-size: 0.9rem;" id="ram-label">--</span>
            </div>
            <div style="position: relative; height: 160px;">
                <canvas id="ram-chart"></canvas>
                <div class="chart-offline-overlay text-body-secondary" id="ram-offline"
                    style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:0.85rem;<%= server.state === 'running' ? 'display:none;' : '' %>">
                    No Data — Server Offline
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Provisioning failure — the server is auto-removed, so the only way
     forward is back to the dashboard (static backdrop, no dismiss).
     data-auto-show is set when the page loads AFTER the failure; when it
     loads before, console.js shows it live from the WebSocket event. -->
<div class="modal fade" id="provisionFailedModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false"
     data-auto-show="<%= server.provisionFailed ? 'true' : '' %>">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-danger">error</span>
                    Server Setup Failed
                </h5>
            </div>
            <div class="modal-body">
                <p class="mb-2" id="provision-failed-reason"><%= server.provisionFailed && server.crashReason ? server.crashReason.replace(/^(Provisioning failed|Modpack install failed): /, '') : '' %></p>
                <p class="text-body-secondary mb-0" style="font-size: 0.85rem;">
                    The server and its files have been removed automatically.
                    You can try again with a different version or setup.
                </p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <a href="/dashboard" class="btn btn-success btn-sm d-flex align-items-center gap-1">
                    <span class="material-icons-outlined" style="font-size: 1rem;">arrow_back</span>
                    Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Kill Confirmation Modal -->
<div class="modal fade" id="killModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-danger">dangerous</span>
                    Force Kill Server
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                This will immediately terminate the server process. Unsaved world data may be lost.
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm" id="confirm-kill">Kill Server</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-danger">delete_forever</span>
                    Delete Server
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                This will permanently delete <strong><%= server.name %></strong> and all of its files. This cannot be undone.
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm" id="confirm-delete">Delete Server</button>
            </div>
        </div>
    </div>
</div>


<%- include('../partials/foot', { scripts: ['/vendor/chart.js/chart.umd.min.js', '/js/serverState.js', '/js/console.js'] }) %>
