<%- include('partials/head', { title: 'Account Settings', navbar: true }) %>

<div class="row justify-content-center">
    <div class="col-lg-6 col-xl-5">
        <h4 class="fw-bold mb-4 d-flex align-items-center gap-2">
            <span class="material-icons-outlined">settings</span>
            Account Settings
        </h4>

        <!-- API Keys Card -->
        <div class="card mb-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold text-body-secondary mb-0 d-flex align-items-center gap-2">
                        <span class="material-icons-outlined" style="font-size: 1.2rem;">key</span>
                        API Keys
                    </h6>
                    <button type="button" class="btn btn-success btn-sm d-flex align-items-center gap-1" id="create-key-btn">
                        <span class="material-icons-outlined" style="font-size: 1rem;">add</span>
                        New Key
                    </button>
                </div>
                <p class="text-body-secondary small mb-3">
                    API keys let scripts and integrations call the Craftbox API on your behalf. Keys inherit your account's permissions.
                </p>

                <% if (!apiKeys || apiKeys.length === 0) { %>
                    <div class="text-center text-body-secondary py-4">
                        <span class="material-icons-outlined mb-2" style="font-size: 3rem; opacity: 0.3;">key</span>
                        <p class="mb-0">No API keys yet. Create one above to get started.</p>
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Prefix</th>
                                    <th>Created</th>
                                    <th>Last used</th>
                                    <th style="width: 48px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <% apiKeys.forEach(function(key) { %>
                                    <tr>
                                        <td><%= key.name %></td>
                                        <td class="text-body-secondary small"><code><%= key.prefix %>…</code></td>
                                        <td class="text-body-secondary small">
                                            <span class="format-date" data-iso="<%= key.createdAt %>"></span>
                                        </td>
                                        <td class="text-body-secondary small">
                                            <% if (key.lastUsedAt) { %>
                                                <span class="format-date" data-iso="<%= key.lastUsedAt %>"></span>
                                            <% } else { %>
                                                Never
                                            <% } %>
                                        </td>
                                        <td class="text-end">
                                            <button type="button"
                                                class="btn btn-outline-danger btn-sm d-inline-flex align-items-center justify-content-center delete-key-btn"
                                                style="width: 32px; height: 32px; padding: 0;"
                                                title="Delete"
                                                data-key-id="<%= key.id %>"
                                                data-key-name="<%= key.name %>"
                                                data-key-prefix="<%= key.prefix %>">
                                                <span class="material-icons-outlined" style="font-size: 1rem;">delete</span>
                                            </button>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Change Username / Password Card -->
        <div class="card">
            <div class="card-body p-4">
                <form id="accountForm">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <h6 class="fw-bold text-body-secondary mb-3">Change Username</h6>

                    <div class="mb-3">
                        <label for="newUsername" class="form-label">New Username</label>
                        <div class="input-group">
                            <span class="input-group-text"><span class="material-icons-outlined" style="font-size: 1.2rem;">person</span></span>
                            <input type="text" class="form-control" id="newUsername" name="newUsername"
                                minlength="3" maxlength="32" pattern="[a-zA-Z0-9_\-]+"
                                placeholder="<%= user.username %>"
                                autocomplete="username">
                        </div>
                        <div class="form-text">Leave blank to keep your current username. Letters, numbers, hyphens, and underscores only.</div>
                    </div>

                    <hr class="my-4">

                    <h6 class="fw-bold text-body-secondary mb-3">Change Password</h6>

                    <div class="mb-3">
                        <label for="newPassword" class="form-label">New Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><span class="material-icons-outlined" style="font-size: 1.2rem;">lock</span></span>
                            <input type="password" class="form-control" id="newPassword" name="newPassword"
                                minlength="8" placeholder="New password"
                                autocomplete="new-password">
                        </div>
                        <div class="form-text">Leave blank to keep your current password. Minimum 8 characters.</div>
                    </div>

                    <div class="mb-3">
                        <label for="confirmNewPassword" class="form-label">Confirm New Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><span class="material-icons-outlined" style="font-size: 1.2rem;">lock</span></span>
                            <input type="password" class="form-control" id="confirmNewPassword" name="confirmNewPassword"
                                minlength="8" placeholder="Confirm new password"
                                autocomplete="new-password">
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="mb-4">
                        <label for="currentPassword" class="form-label fw-bold required-star">Current Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><span class="material-icons-outlined" style="font-size: 1.2rem;">key</span></span>
                            <input type="password" class="form-control" id="currentPassword" name="currentPassword"
                                required placeholder="Enter your current password"
                                autocomplete="current-password">
                        </div>
                        <div class="form-text">Required to confirm any changes.</div>
                    </div>

                    <button type="button" class="btn btn-success w-100 d-flex align-items-center justify-content-center gap-2"
                        id="saveBtn" disabled>
                        <span class="material-icons-outlined" style="font-size: 1.2rem;">save</span>
                        Save Changes
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Confirmation Modal (for account changes) -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2" id="confirmModalLabel">
                    <span class="material-icons-outlined text-warning">warning</span>
                    Confirm Changes
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>You will be <strong>logged out</strong> after saving your changes. Please sign in again using your new credentials.</p>
                <p class="text-body-secondary mb-0">Make sure you remember your new details before proceeding.</p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success d-flex align-items-center gap-2" id="confirmSaveBtn">
                    <span class="material-icons-outlined" style="font-size: 1.2rem;">check</span>
                    Save & Log Out
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Create API Key Modal -->
<div class="modal fade" id="createKeyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-success">key</span>
                    Generate API Key
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="create-key-form" novalidate>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="keyName" class="form-label required-star">Key Name</label>
                        <input type="text" class="form-control form-control-sm" id="keyName" name="name"
                            placeholder="e.g. ci-bot" maxlength="50" autocomplete="off"
                            pattern="[A-Za-z0-9 _\-]{1,50}" required>
                        <div class="form-text">1-50 characters. Letters, numbers, spaces, hyphens, underscores.</div>
                    </div>
                    <div class="alert alert-warning d-flex align-items-center gap-2 py-2 px-3 mb-0" role="alert">
                        <span class="material-icons-outlined" style="font-size: 1.2rem;">warning</span>
                        <small>The key will be shown once. Make sure you save it.</small>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success btn-sm" id="confirm-create-key-btn" disabled>Generate Key</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Show Generated Key Modal (shown once after creation) -->
<div class="modal fade" id="showKeyModal" tabindex="-1" aria-hidden="true"
    data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-success">check_circle</span>
                    Key Generated
                </h5>
            </div>
            <div class="modal-body">
                <p class="mb-2">Here is your new API key. <strong>Copy it now</strong> — it will not be shown again.</p>
                <div class="input-group mb-3">
                    <input type="text" class="form-control font-monospace" id="generatedKeyValue" readonly>
                    <button type="button" class="btn btn-outline-secondary d-flex align-items-center justify-content-center" id="copy-key-btn" title="Copy to clipboard"
                        style="width: 42px;">
                        <span class="material-icons-outlined" style="font-size: 1.1rem;">content_copy</span>
                    </button>
                </div>
                <div class="alert alert-warning d-flex align-items-center gap-2 py-2 px-3 mb-0" role="alert">
                    <span class="material-icons-outlined" style="font-size: 1.2rem;">lock</span>
                    <small>Treat this like a password. Anyone with it can use the API as you.</small>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-success" id="saved-key-btn">I've saved it</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete API Key Modal -->
<div class="modal fade" id="deleteKeyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-danger">delete</span>
                    Delete API Key
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">Delete key <strong id="deleteKeyName"></strong> (<code id="deleteKeyPrefix"></code>…)?</p>
                <p class="text-body-secondary small mb-0">Any scripts using this key will immediately stop working.</p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm" id="confirm-delete-key-btn">Delete Key</button>
            </div>
        </div>
    </div>
</div>

<%- include('partials/foot', { scripts: ['/js/account.js'] }) %>
