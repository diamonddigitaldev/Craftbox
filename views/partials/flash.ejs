<% if (messages && (messages.error || messages.success || messages.warning || messages.info)) { %>
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1090;">
    <% if (messages.error) { %>
    <div class="toast align-items-center text-bg-danger border-0" role="alert" data-bs-autohide="true" data-bs-delay="5000">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center gap-2">
                <span class="material-icons-outlined" style="font-size: 1.2rem;">error</span>
                <%= messages.error %>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
    <% } %>
    <% if (messages.success) { %>
    <div class="toast align-items-center text-bg-success border-0" role="alert" data-bs-autohide="true" data-bs-delay="4000">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center gap-2">
                <span class="material-icons-outlined" style="font-size: 1.2rem;">check_circle</span>
                <%= messages.success %>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
    <% } %>
    <% if (messages.warning) { %>
    <div class="toast align-items-center text-bg-warning border-0" role="alert" data-bs-autohide="true" data-bs-delay="5000">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center gap-2">
                <span class="material-icons-outlined" style="font-size: 1.2rem;">warning</span>
                <%= messages.warning %>
            </div>
            <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
    <% } %>
    <% if (messages.info) { %>
    <div class="toast align-items-center text-bg-info border-0" role="alert" data-bs-autohide="true" data-bs-delay="4000">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center gap-2">
                <span class="material-icons-outlined" style="font-size: 1.2rem;">info</span>
                <%= messages.info %>
            </div>
            <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
    <% } %>
</div>
<% } %>
