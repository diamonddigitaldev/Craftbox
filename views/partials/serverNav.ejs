<%
// stateColors / stateIcons / stateDisplayNames / getState* helpers come from
// res.locals (injected by serverStateMeta.injectIntoLocals middleware).
const _displayVersion = (server.serverType || 'vanilla') === 'custom'
    ? '(Unknown Version)'
    : (server.version || '(Unknown Version)');
%>
<div class="d-flex flex-wrap align-items-center gap-2 mb-3" id="server-nav-header" data-state="<%= server.state %>">
    <a href="/dashboard" class="btn btn-outline-secondary btn-sm d-flex align-items-center">
        <span class="material-icons-outlined" style="font-size: 1.2rem;">arrow_back</span>
    </a>
    <h4 class="mb-0"><%= server.name %></h4>
    <span class="badge bg-<%= getStateColor(server.state) %> d-flex align-items-center gap-1 server-state-badge" id="server-state-badge">
        <span class="material-icons-outlined" style="font-size: 0.9rem;" id="state-icon"><%= getStateIcon(server.state) %></span>
        <span id="state-text"><%= getStateDisplayName(server.state) %></span>
    </span>
    <span class="text-body-secondary ms-2 d-flex align-items-center gap-1" style="font-size: 0.85rem;">
        <img src="/img/server-types/<%= server.serverType || 'vanilla' %>.svg" alt="" class="server-type-logo">
        <%= (server.serverType || 'vanilla').charAt(0).toUpperCase() + (server.serverType || 'vanilla').slice(1) %> <%= _displayVersion %> &middot; Port <%= server.port %> &middot; <%= server.memory %> MB
    </span>
</div>
<ul class="nav nav-pills mb-3" id="server-nav">
    <li class="nav-item">
        <a class="nav-link d-flex align-items-center gap-1<%= active === 'console' ? ' active' : '' %>" href="/servers/<%= server.id %>">
            <span class="material-icons-outlined" style="font-size: 1rem;">terminal</span> Console
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link d-flex align-items-center gap-1<%= active === 'settings' ? ' active' : '' %>" href="/servers/<%= server.id %>/edit">
            <span class="material-icons-outlined" style="font-size: 1rem;">edit</span> Settings
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link d-flex align-items-center gap-1<%= active === 'properties' ? ' active' : '' %>" href="/servers/<%= server.id %>/properties">
            <span class="material-icons-outlined" style="font-size: 1rem;">tune</span> Properties
        </a>
    </li>
    <%
    const _contentTypes = { paper: 'Plugins', purpur: 'Plugins', folia: 'Plugins', fabric: 'Mods', forge: 'Mods' };
    const _contentLabel = _contentTypes[server.serverType] || null;
    const _contentIcon = 'extension';
    %>
    <% if (_contentLabel) { %>
    <li class="nav-item">
        <a class="nav-link d-flex align-items-center gap-1<%= active === 'plugins' ? ' active' : '' %>" href="/servers/<%= server.id %>/plugins">
            <span class="material-icons-outlined" style="font-size: 1rem;"><%= _contentIcon %></span> <%= _contentLabel %>
        </a>
    </li>
    <% } %>
    <li class="nav-item">
        <a class="nav-link d-flex align-items-center gap-1<%= active === 'files' ? ' active' : '' %>" href="/servers/<%= server.id %>/files">
            <span class="material-icons-outlined" style="font-size: 1rem;">folder</span> Files
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link d-flex align-items-center gap-1<%= active === 'backups' ? ' active' : '' %>" href="/servers/<%= server.id %>/backups">
            <span class="material-icons-outlined" style="font-size: 1rem;">backup</span> Backups
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link d-flex align-items-center gap-1<%= active === 'events' ? ' active' : '' %>" href="/servers/<%= server.id %>/events">
            <span class="material-icons-outlined" style="font-size: 1rem;">history</span> Events
        </a>
    </li>
</ul>
