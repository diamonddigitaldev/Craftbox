<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' | Craftbox' : 'Craftbox' %></title>
    <link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/vendor/material-icons/material-icons.css">
    <link rel="stylesheet" href="/vendor/material-icons/outlined.css">
    <link rel="stylesheet" href="/css/app.css">
    <link rel="icon" href="/img/craftbox.ico">
    <link rel="manifest" href="/manifest.json">
    <link rel="apple-touch-icon" href="/img/craftbox.png">
    <% if (typeof description !== 'undefined' && description) { %><meta name="description" content="<%= description %>"><% } %>
    <meta property="og:site_name" content="Craftbox">
    <meta property="og:title" content="<%= typeof title !== 'undefined' && title ? title + ' | Craftbox' : 'Craftbox' %>">
    <% if (typeof description !== 'undefined' && description) { %><meta property="og:description" content="<%= description %>"><% } %>
    <meta property="og:type" content="website">
    <meta property="og:image" content="/img/craftbox.png">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Craftbox">
    <meta name="theme-color" content="#4caf50">
</head>
<body>
<% if (typeof navbar !== 'undefined' && navbar) { %>
    <%- include('navbar', { user: typeof user !== 'undefined' ? user : null }) %>
<% } %>
<main class="<%= typeof fluid !== 'undefined' && fluid ? 'container-fluid' : 'container' %> py-4">
    <%- include('flash', { messages: typeof messages !== 'undefined' ? messages : {} }) %>
