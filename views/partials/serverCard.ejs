<%
const stateColors = {
    stopped: 'secondary',
    starting: 'info',
    running: 'success',
    stopping: 'warning',
    crashed: 'danger',
    backing_up: 'info',
    restoring: 'info'
};
const stateIcons = {
    stopped: 'stop_circle',
    starting: 'hourglass_top',
    running: 'play_circle',
    stopping: 'pending',
    crashed: 'error',
    backing_up: 'backup',
    restoring: 'settings_backup_restore'
};
const stateDisplayNames = {
    backing_up: 'Backing Up',
    restoring: 'Restoring'
};
const color = stateColors[server.state] || 'secondary';
const icon = stateIcons[server.state] || 'help';
const displayVersion = (server.serverType || 'vanilla') === 'custom'
    ? '(Unknown Version)'
    : (server.version || '(Unknown Version)');
%>
<div class="col-md-6 col-xl-4 mb-4">
    <div class="card server-card h-100 border-<%= color %>" data-server-id="<%= server.id %>" data-state="<%= server.state %>">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h5 class="card-title mb-1">
                        <a href="/servers/<%= server.id %>" class="text-decoration-none text-light"><%= server.name %></a>
                    </h5>
                    <small class="text-body-secondary d-flex align-items-center gap-1">
                        <img src="/img/server-types/<%= server.serverType || 'vanilla' %>.svg" alt="" class="server-type-logo">
                        <%= (server.serverType || 'vanilla').charAt(0).toUpperCase() + (server.serverType || 'vanilla').slice(1) %> <%= displayVersion %>
                    </small>
                </div>
                <span class="badge bg-<%= color %> d-flex align-items-center gap-1 server-state-badge">
                    <span class="material-icons-outlined" style="font-size: 0.9rem;"><%= icon %></span>
                    <span class="server-state-text"><%= stateDisplayNames[server.state] || server.state.charAt(0).toUpperCase() + server.state.slice(1) %></span>
                </span>
            </div>
            <div class="d-flex flex-wrap gap-3 text-body-secondary mb-3" style="font-size: 0.85rem;">
                <span class="d-flex align-items-center gap-1">
                    <span class="material-icons-outlined" style="font-size: 1rem;">lan</span>
                    Port <%= server.port %>
                </span>
                <span class="d-flex align-items-center gap-1">
                    <span class="material-icons-outlined" style="font-size: 1rem;">memory</span>
                    <%= server.memory %> MB
                </span>
                <span class="d-flex align-items-center gap-1">
                    <span class="material-icons-outlined" style="font-size: 1rem;">people</span>
                    <span class="card-stat-players">0</span> online
                </span>
                <span class="d-flex align-items-center gap-1">
                    <span class="material-icons-outlined" style="font-size: 1rem;">schedule</span>
                    <span class="card-stat-uptime">--</span>
                </span>
            </div>
            <div class="d-flex gap-2 server-actions" data-server-id="<%= server.id %>">
                <button type="button"
                    class="btn btn-success btn-sm d-flex align-items-center gap-1 server-action-btn server-action-start<%= ['stopped', 'crashed'].includes(server.state) ? '' : ' d-none' %>"
                    data-action="start">
                    <span class="material-icons-outlined" style="font-size: 1rem;">play_arrow</span> Start
                </button>
                <button type="button"
                    class="btn btn-warning btn-sm d-flex align-items-center gap-1 server-action-btn server-action-stop<%= ['running', 'starting'].includes(server.state) ? '' : ' d-none' %>"
                    data-action="stop">
                    <span class="material-icons-outlined" style="font-size: 1rem;">stop</span> Stop
                </button>
                <button type="button"
                    class="btn btn-info btn-sm d-flex align-items-center gap-1 server-action-btn server-action-restart<%= server.state === 'running' ? '' : ' d-none' %>"
                    data-action="restart">
                    <span class="material-icons-outlined" style="font-size: 1rem;">restart_alt</span> Restart
                </button>
                <a href="/servers/<%= server.id %>" class="btn btn-outline-light btn-sm d-flex align-items-center gap-1 ms-auto">
                    <span class="material-icons-outlined" style="font-size: 1rem;">settings</span> Manage
                </a>
            </div>
        </div>
        <div class="card-footer bg-danger bg-opacity-10 text-danger small server-crash-footer<%= server.state === 'crashed' ? '' : ' d-none' %>">
            <span class="material-icons-outlined align-middle me-1" style="font-size: 1rem;">warning</span>
            Server crashed<%= server.crashReason === 'oom' ? ' (Out of Memory)' : '' %> — Exit code: <%= server.exitCode %>
        </div>
    </div>
</div>
