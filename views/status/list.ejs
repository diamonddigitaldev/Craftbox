<%- include('../partials/head', { title: 'Server Status', navbar: false, fluid: false }) %>

<div class="text-center mb-4 mt-3">
    <img src="/img/craftbox.png" alt="Craftbox" style="width: 2.5rem; height: 2.5rem; object-fit: contain;">
    <h3 class="fw-bold mt-2">Server Status</h3>
    <p class="text-body-secondary">Select a server to view detailed information.</p>
</div>

<% if (servers.length === 0) { %>
<div class="text-center py-5">
    <span class="material-icons-outlined text-body-secondary mb-2" style="font-size: 3rem; opacity: 0.3;">dns</span>
    <p class="text-body-secondary">No public servers available.</p>
</div>
<% } else { %>
<div class="row justify-content-center">
    <% servers.forEach(function(server) { %>
    <%
    // SECURITY BOUNDARY — do NOT replace with the shared getStateColor/getStateIcon
    // helpers from src/utils/serverStateMeta.js. These maps intentionally only
    // include the five SAFE_PUBLIC_STATES so that any non-public state which
    // somehow slipped past sanitizeForPublic() in src/routes/status.js falls
    // back to a generic 'secondary' badge instead of rendering with its real
    // (e.g. "Backing Up") label.
    const stateColors = { stopped: 'secondary', starting: 'info', running: 'success', stopping: 'warning', crashed: 'danger' };
    const stateIcons = { stopped: 'stop_circle', starting: 'hourglass_top', running: 'play_circle', stopping: 'pending', crashed: 'error' };
    const color = stateColors[server.state] || 'secondary';
    const icon = stateIcons[server.state] || 'help';
    %>
    <div class="col-md-6 col-xl-4 mb-4">
        <a href="/status/<%= server.id %>" class="text-decoration-none">
            <div class="card status-card h-100 border-<%= color %>" data-server-id="<%= server.id %>" data-state="<%= server.state %>">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title mb-0 text-light"><%= server.name %></h5>
                        <span class="badge bg-<%= color %> d-flex align-items-center gap-1 status-badge">
                            <span class="material-icons-outlined status-icon" style="font-size: 0.9rem;"><%= icon %></span>
                            <span class="status-text"><%= server.state.charAt(0).toUpperCase() + server.state.slice(1) %></span>
                        </span>
                    </div>
                    <small class="text-body-secondary d-flex align-items-center gap-1 mb-3">
                        <img src="/img/server-types/<%= server.serverType %>.svg" alt="" class="server-type-logo">
                        <%= server.serverType.charAt(0).toUpperCase() + server.serverType.slice(1) %>
                        <%= server.version || '' %>
                    </small>
                    <div class="d-flex flex-wrap gap-3 text-body-secondary" style="font-size: 0.85rem;">
                        <span class="d-flex align-items-center gap-1">
                            <span class="material-icons-outlined" style="font-size: 1rem;">people</span>
                            <span class="status-players"><%= server.playerCount %></span> online
                        </span>
                        <span class="d-flex align-items-center gap-1">
                            <span class="material-icons-outlined" style="font-size: 1rem;">schedule</span>
                            <span class="status-uptime"><%= server.uptimeFormatted %></span>
                        </span>
                        <span class="d-flex align-items-center gap-1">
                            <span class="material-icons-outlined" style="font-size: 1rem;">lan</span>
                            <span class="server-ip" data-port="<%= server.port %>"<% if (server.advertisedIp) { %> data-ip="<%= server.advertisedIp %>"<% } %>>:<%= server.port %></span>
                        </span>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <% }) %>
</div>
<% } %>

<div class="text-center mb-4">
    <small class="text-body-secondary d-flex align-items-center justify-content-center gap-1">
        Powered by
        <img src="/img/craftbox.png" alt="Craftbox" style="width: 0.9rem; height: 0.9rem; object-fit: contain;">
        <strong>Craftbox</strong>
    </small>
</div>

<%- include('../partials/foot', { scripts: ['/js/status.js'] }) %>
