<%- include('partials/head', { title: 'Dashboard', navbar: true, fluid: true }) %>

<input type="hidden" name="_csrf" value="<%= csrfToken %>">

<div class="d-flex flex-column flex-md-row justify-content-md-between align-items-start align-items-md-center gap-2 mb-4">
    <h4 class="mb-0 d-flex align-items-center gap-2">
        <span class="material-icons-outlined">dns</span>
        Servers
    </h4>
    <div class="d-flex flex-wrap gap-2">
        <a href="/modpacks" class="btn btn-outline-light btn-sm text-nowrap d-flex align-items-center gap-1">
            <span class="material-icons-outlined" style="font-size: 1rem;">widgets</span>
            Create from modpack...
        </a>
        <button type="button" class="btn btn-outline-light btn-sm text-nowrap d-flex align-items-center gap-1" id="import-server-btn">
            <span class="material-icons-outlined" style="font-size: 1rem;">upload</span>
            Import
        </button>
        <a href="/servers/create" class="btn btn-success btn-sm text-nowrap d-flex align-items-center gap-1">
            <span class="material-icons-outlined" style="font-size: 1rem;">add</span>
            New Server
        </a>
    </div>
</div>

<% if (servers && servers.length > 0) { %>
    <div id="server-grid">
        <!-- Group folder tiles (click to open the group's page) -->
        <div class="row<%= serverGroups.length === 0 ? ' d-none' : '' %>" id="group-tiles">
            <% serverGroups.forEach(function(group) { %>
            <div class="col-6 col-md-4 col-xl-3 mb-4" data-group-name="<%= group.name %>">
                <a href="/dashboard/groups/<%= encodeURIComponent(group.name) %>" class="text-decoration-none">
                    <div class="card group-tile h-100" style="--group-color: <%= group.color %>;">
                        <div class="card-body d-flex align-items-center gap-3">
                            <span class="material-icons-outlined group-tile-icon"
                                style="font-size: 2rem;">folder</span>
                            <div class="overflow-hidden">
                                <div class="text-light fw-semibold text-truncate"><%= group.name %></div>
                                <small class="text-body-secondary text-truncate d-block">
                                    <span class="group-tile-count"><%= group.count %></span>
                                    server<%= group.count === 1 ? '' : 's' %>
                                </small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <% }) %>
        </div>

        <div class="row" id="ungrouped-grid">
            <% ungrouped.forEach(function(server) { %>
                <%- include('partials/serverCard', { server, csrfToken, groupNames }) %>
            <% }) %>
        </div>
    </div>

    <!-- Template cloned by groups.js when a live move creates a brand-new group -->
    <template id="group-tile-template">
        <div class="col-6 col-md-4 col-xl-3 mb-4" data-group-name="">
            <a href="#" class="text-decoration-none">
                <div class="card group-tile h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <span class="material-icons-outlined group-tile-icon" style="font-size: 2rem;">folder</span>
                        <!-- --group-color set by groups.js when cloned -->
                        <div class="overflow-hidden">
                            <div class="text-light fw-semibold text-truncate group-tile-name"></div>
                            <small class="text-body-secondary text-truncate d-block">
                                <span class="group-tile-count">0</span> <span class="group-tile-noun">servers</span>
                            </small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </template>

    <%- include('partials/addGroupModal', { groupNames }) %>
<% } else { %>
    <div class="text-center py-5">
        <span class="material-icons-outlined text-body-secondary mb-3" style="font-size: 4rem;">dns</span>
        <h5 class="text-body-secondary">No servers yet</h5>
        <p class="text-body-secondary mb-4">Create your first Minecraft server to get started.</p>
        <a href="/servers/create" class="btn btn-success btn-lg d-inline-flex align-items-center gap-2">
            <span class="material-icons-outlined">add</span>
            Create Server
        </a>
    </div>
<% } %>

<!-- Import server modal -->
<div class="modal fade" id="importServerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined">upload</span>
                    Import Server
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-body-secondary" style="font-size: 0.85rem;">
                    Upload a transfer archive exported from another Craftbox instance
                    (Settings &rarr; Export / Transfer). You can also drop a .zip
                    anywhere on this page.
                </p>
                <input type="file" class="form-control" id="import-file" accept=".zip">
                <div class="progress mt-3 d-none" id="import-progress" style="height: 6px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width: 0%"></div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success btn-sm d-flex align-items-center gap-1"
                    id="import-confirm" disabled>
                    <span class="material-icons-outlined" style="font-size: 1rem;">upload</span>
                    Import
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Create server from a dropped .mrpack -->
<div class="modal fade" id="mrpackCreateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-success">widgets</span>
                    Create Server from Modpack
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="mrpack-create-form">
                <div class="modal-body">
                    <p class="text-body-secondary d-flex align-items-center gap-2 mb-3" style="font-size: 0.85rem;">
                        <span class="material-icons-outlined" style="font-size: 1rem;">upload_file</span>
                        <span class="text-truncate" id="mrpack-drop-filename"></span>
                    </p>
                    <div class="mb-3">
                        <label for="mrpack-name" class="form-label required-star">Server Name</label>
                        <input type="text" class="form-control" id="mrpack-name" required minlength="1"
                            maxlength="50" pattern="[a-zA-Z0-9 _\-]+">
                        <div class="form-text">1-50 characters. Letters, numbers, spaces, hyphens, underscores.</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label for="mrpack-port" class="form-label required-star">Server Port</label>
                            <input type="number" class="form-control" id="mrpack-port" value="25565"
                                min="1024" max="65535" required>
                        </div>
                        <div class="col-6">
                            <label for="mrpack-memory" class="form-label required-star">Memory (MB)</label>
                            <input type="number" class="form-control" id="mrpack-memory" value="4096"
                                min="512" max="65536" required>
                            <div class="form-text">RAM allocated to the server (-Xmx). Modpacks usually need 4-8 GB.</div>
                        </div>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="mrpack-eula" required>
                        <label class="form-check-label required-star" for="mrpack-eula">
                            I agree to the <a href="https://aka.ms/MinecraftEULA" target="_blank"
                                rel="noopener noreferrer">Minecraft End User License Agreement</a>
                        </label>
                        <div class="form-text">You must accept the EULA before creating a server.</div>
                    </div>
                    <div class="progress mt-3 d-none" id="mrpack-progress" style="height: 6px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 0%"></div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success btn-sm d-flex align-items-center gap-1"
                        id="mrpack-create-confirm" data-validate-required disabled>
                        <span class="material-icons-outlined" style="font-size: 1rem;">add</span>
                        Create Server
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Drop zone overlay (hidden until drag) -->
<div id="import-drop-overlay" class="d-none position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
    style="z-index: 1050; background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); pointer-events: none;">
    <div class="text-center">
        <span class="material-icons-outlined text-success" style="font-size: 4rem;">upload_file</span>
        <h4 class="text-white mt-2">Drop a .zip to import a server, or a .mrpack to create one...</h4>
    </div>
</div>

<%- include('partials/foot', { scripts: ['/js/dashboard.js', '/js/group-picker.js', '/js/groups.js', '/js/import.js'] }) %>
