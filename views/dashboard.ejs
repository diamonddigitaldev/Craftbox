<%- include('partials/head', { title: 'Dashboard', navbar: true, fluid: true }) %>

<input type="hidden" name="_csrf" value="<%= csrfToken %>">

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 d-flex align-items-center gap-2">
        <span class="material-icons-outlined">dns</span>
        Servers
    </h4>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-light d-flex align-items-center gap-1" id="import-server-btn">
            <span class="material-icons-outlined" style="font-size: 1.2rem;">upload</span>
            Import
        </button>
        <a href="/servers/create" class="btn btn-success d-flex align-items-center gap-1">
            <span class="material-icons-outlined" style="font-size: 1.2rem;">add</span>
            New Server
        </a>
    </div>
</div>

<% if (servers && servers.length > 0) { %>
    <div id="server-grid">
        <% serverGroups.forEach(function(group, i) { %>
            <button type="button"
                class="btn group-toggle d-flex align-items-center gap-2 mb-3 p-0 border-0"
                data-bs-toggle="collapse" data-bs-target="#group-section-<%= i %>"
                aria-expanded="true" aria-controls="group-section-<%= i %>">
                <span class="material-icons-outlined">folder</span>
                <span class="fw-semibold"><%= group.name %></span>
                <span class="badge bg-secondary"><%= group.servers.length %></span>
                <span class="material-icons-outlined group-arrow" style="font-size: 1.1rem;">expand_more</span>
            </button>
            <div class="collapse show group-section" id="group-section-<%= i %>" data-group-name="<%= group.name %>">
                <div class="row">
                    <% group.servers.forEach(function(server) { %>
                        <%- include('partials/serverCard', { server, csrfToken, groupNames }) %>
                    <% }) %>
                </div>
            </div>
        <% }) %>
        <% if (ungrouped.length > 0) { %>
            <div class="row">
                <% ungrouped.forEach(function(server) { %>
                    <%- include('partials/serverCard', { server, csrfToken, groupNames }) %>
                <% }) %>
            </div>
        <% } %>
    </div>

    <!-- Assign group modal (used by the "New group…" card menu item) -->
    <div class="modal fade" id="assignGroupModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title d-flex align-items-center gap-2">
                        <span class="material-icons-outlined">create_new_folder</span>
                        New group
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <label for="assign-group-name" class="form-label">Group name</label>
                    <input type="text" class="form-control" id="assign-group-name" list="group-options"
                        maxlength="30" pattern="[a-zA-Z0-9 _\-]+" placeholder="e.g. Survival Network">
                    <datalist id="group-options">
                        <% groupNames.forEach(function(g) { %>
                        <option value="<%= g %>"></option>
                        <% }) %>
                    </datalist>
                    <div class="form-text">1-30 characters. Letters, numbers, spaces, hyphens, underscores.</div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success btn-sm d-flex align-items-center gap-1"
                        id="assign-group-confirm">
                        <span class="material-icons-outlined" style="font-size: 1rem;">check</span>
                        Move
                    </button>
                </div>
            </div>
        </div>
    </div>
<% } else { %>
    <div class="text-center py-5">
        <span class="material-icons-outlined text-body-secondary mb-3" style="font-size: 4rem;">dns</span>
        <h5 class="text-body-secondary">No servers yet</h5>
        <p class="text-body-secondary mb-4">Create your first Minecraft server to get started.</p>
        <a href="/servers/create" class="btn btn-success btn-lg d-inline-flex align-items-center gap-2">
            <span class="material-icons-outlined">add</span>
            Create Server
        </a>
    </div>
<% } %>

<!-- Import server modal -->
<div class="modal fade" id="importServerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <span class="material-icons-outlined">upload</span>
                    Import Server
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-body-secondary" style="font-size: 0.85rem;">
                    Upload a transfer archive exported from another Craftbox instance
                    (Settings &rarr; Export / Transfer). Maximum archive size: 4 GB.
                </p>
                <input type="file" class="form-control" id="import-file" accept=".zip">
                <div class="progress mt-3 d-none" id="import-progress" style="height: 6px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width: 0%"></div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success btn-sm d-flex align-items-center gap-1"
                    id="import-confirm" disabled>
                    <span class="material-icons-outlined" style="font-size: 1rem;">upload</span>
                    Import
                </button>
            </div>
        </div>
    </div>
</div>

<%- include('partials/foot', { scripts: ['/js/dashboard.js', '/js/import.js'] }) %>
