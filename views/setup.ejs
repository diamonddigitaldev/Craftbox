<%- include('partials/head', { title: 'Setup', navbar: false }) %>

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-sm-10 col-md-6 col-lg-5 col-xl-4">
        <div class="text-center mb-4">
            <img src="/img/craftbox.png" alt="Craftbox" style="width: 3.5rem; height: 3.5rem; object-fit: contain;">
            <h2 class="fw-bold mt-2">Welcome to Craftbox</h2>
            <p class="text-body-secondary">Create your admin account to get started.</p>
        </div>
        <div class="card">
            <div class="card-body p-4">
                <form method="POST" action="/setup" novalidate>
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="mb-3">
                        <label for="username" class="form-label required-star">Username</label>
                        <div class="input-group">
                            <span class="input-group-text"><span class="material-icons-outlined" style="font-size: 1.2rem;">person</span></span>
                            <input type="text" class="form-control" id="username" name="username" required autofocus
                                minlength="3" maxlength="32" pattern="[a-zA-Z0-9_\-]+"
                                placeholder="admin">
                        </div>
                        <div class="form-text">3-32 characters. Letters, numbers, hyphens, underscores.</div>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label required-star">Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><span class="material-icons-outlined" style="font-size: 1.2rem;">lock</span></span>
                            <input type="password" class="form-control" id="password" name="password" required minlength="8" placeholder="••••••••">
                        </div>
                        <div class="form-text">Minimum 8 characters.</div>
                    </div>
                    <div class="mb-4">
                        <label for="confirmPassword" class="form-label required-star">Confirm Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><span class="material-icons-outlined" style="font-size: 1.2rem;">lock</span></span>
                            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required minlength="8" placeholder="••••••••">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success w-100 d-flex align-items-center justify-content-center gap-2" data-validate-required disabled>
                        <span class="material-icons-outlined" style="font-size: 1.2rem;">rocket_launch</span>
                        Create Account
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('partials/foot', { scripts: [] }) %>
